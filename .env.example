# ContaFlow — Variables de entorno para despliegue Vercel (SaaS / Tier 1)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copia este archivo como .env.local para desarrollo local.
# 2. En Vercel: Settings → Environment Variables → pega cada valor.
# 3. Nunca commitear .env.local ni .env.production al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── BASE DE DATOS (Neon) ──────────────────────────────────────────────────────
# Neon Dashboard → Connection Details → Pooled connection (para la app)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Neon Dashboard → Connection Details → Direct connection (para migraciones)
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ── AUTENTICACIÓN (Clerk) ─────────────────────────────────────────────────────
# Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── URL DE LA APLICACIÓN ──────────────────────────────────────────────────────
# URL pública de la app, sin trailing slash.
# En Vercel, VERCEL_URL se configura automáticamente — solo necesitas esta
# si tienes un dominio personalizado (ej: https://app.contaflow.com.ve)
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# ── FIRMA DIGITAL (PA-121) ────────────────────────────────────────────────────
# Clave AES-256 para cifrar certificados .p12 en DB.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OBLIGATORIO para firma digital de documentos fiscales.
CERT_ENCRYPTION_SECRET=

# ── PORTAL DEL EMPLEADO ───────────────────────────────────────────────────────
# Clave HMAC-SHA256 para firmar tokens JWT del portal de empleados.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OBLIGATORIO — sin este secreto los tokens son inválidos.
EMPLOYEE_PORTAL_SECRET=

# ── RATE LIMITING (Upstash Redis) ─────────────────────────────────────────────
# Upstash Console → Redis → REST API
# Si no se configura → rate limiting es no-op (permite todo).
UPSTASH_REDIS_REST_URL=https://YOUR_ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── QSTASH (Upstash) — Webhooks y reintentos SENIAT ──────────────────────────
# Upstash Console → QStash → Settings
# Si no se configura → los envíos al SENIAT se crean en DB pero no se encolan.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── INTELIGENCIA ARTIFICIAL ───────────────────────────────────────────────────
# Al menos uno requerido para OCR, conciliación bancaria, asistente contable,
# detector de anomalías y resumen de tareas pendientes.
#
# Gemini (Google AI Studio — gratuito con límites): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── SENTRY — MONITOREO DE ERRORES (OPCIONAL) ─────────────────────────────────
# Dejar vacío para deshabilitar. Crear proyecto en sentry.io.
# SENTRY_DSN se usa server-side; NEXT_PUBLIC_SENTRY_DSN se usa en el cliente.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── PAGOS (NOWPayments) — OPCIONAL ───────────────────────────────────────────
# Configurar cuando esté disponible el dominio de producción.
# NOWPayments Dashboard → Store Settings
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET_KEY=
NOWPAYMENTS_SANDBOX=true

# ── NOTIFICACIONES EMAIL (Resend) — OPCIONAL ─────────────────────────────────
# Resend Dashboard → API Keys: https://resend.com/api-keys
# Si no se configura → emails no se envían (degradación graceful).
RESEND_API_KEY=
# Dirección remitente verificada en Resend (debe pertenecer a tu dominio)
RESEND_FROM=ContaFlow <notificaciones@tudominio.com>

# ── CRON SECRET — RECOMENDADO ─────────────────────────────────────────────────
# Vercel inyecta este secreto en la cabecera Authorization de los Cron Jobs.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Sin este valor → el endpoint /api/cron/* acepta cualquier petición en desarrollo.
CRON_SECRET=

# ── TASAS BCV — OPCIONAL ──────────────────────────────────────────────────────
# URLs del servicio BCV para tasas de cambio. Si no se configuran se usan
# las URLs por defecto en BcvFetchService.ts (scrapers oficiales BCV).
# BCV_API_URL=https://...
# BCV_EUR_API_URL=https://...
