datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum CompanyStatus {
  ACTIVE
  ARCHIVED
}

enum CompanyPlan {
  FREE
  PRO
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum UserRole {
  ADMIN
  ACCOUNTANT
  VIEWER
}

enum TransactionStatus {
  POSTED    // Contabilizado — inmutable
  VOIDED    // Anulado con contrapartida
}

enum TransactionType {
  DIARIO    // Operaciones normales
  APERTURA  // Inicio del periodo
  AJUSTE    // Correcciones al cierre
  CIERRE    // Cierre del periodo
}

enum RetentionType {
  IVA
  ISLR
  AMBAS
}

enum RetentionStatus {
  PENDING
  ISSUED
  VOIDED
}

enum InvoiceType {
  SALE
  PURCHASE
}

enum InvoiceDocType {
  FACTURA
  NOTA_DEBITO
  NOTA_CREDITO
  REPORTE_Z
  RESUMEN_VENTAS
  PLANILLA_IMPORTACION
  OTRO
}

enum TaxCategory {
  GRAVADA
  EXENTA
  EXONERADA
  NO_SUJETA
  IMPORTACION
}

enum TaxLineType {
  IVA_GENERAL
  IVA_REDUCIDO
  IVA_ADICIONAL
  EXENTO
}

enum Currency {
  VES
  USD
  EUR
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  PAGOMOVIL
  ZELLE
  CASHEA
}

enum InvoicePaymentStatus {
  UNPAID    // Sin pagos
  PARTIAL   // Pagado parcialmente
  PAID      // Cancelado totalmente
  VOIDED    // Factura anulada (deletedAt no nulo)
}

model Company {
  id           String        @id @default(cuid())
  name         String
  transactions Transaction[]
  periods AccountingPeriod[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  rif       String?   @unique  // RIF para Venezuela
  address   String?
  members   CompanyMember[]
  accounts  Account[]
  status CompanyStatus @default(ACTIVE)
  plan CompanyPlan @default(FREE)
  isSpecialContributor Boolean @default(false)
  retenciones Retencion[]
  igtfTransactions IGTFTransaction[]
  invoices    Invoice[]
  controlNumberSequences ControlNumberSequence[]
  retentionSequences     RetentionSequence[]
  exchangeRates          ExchangeRate[]
  paymentRecords         PaymentRecord[]
  // Fase 16: Cartera CxC/CxP
  paymentTermDays             Int     @default(30)
  invoicePayments             InvoicePayment[]
  // Fase 17: Conciliación Bancaria
  bankAccounts                BankAccount[]
  // Fase 15: Cierre de ejercicio económico
  resultAccountId             String?
  resultAccount               Account?         @relation("ResultAccount", fields: [resultAccountId], references: [id], onDelete: Restrict)
  retainedEarningsAccountId   String?
  retainedEarningsAccount     Account?         @relation("RetainedEarningsAccount", fields: [retainedEarningsAccountId], references: [id], onDelete: Restrict)
  fiscalYearCloses            FiscalYearClose[]
  // Fase 13C Bloque 3: Snapshots de saldos por período
  periodSnapshots             PeriodSnapshot[]
}

model CompanyMember {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole @default(ACCOUNTANT)
  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])
  @@unique([userId, companyId])
}

model Account {
  id             String         @id @default(cuid())
  name           String
  code           String
  type           AccountType
  description    String?
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id])
  journalEntries JournalEntry[]
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  // Fase 15: relaciones inversas para cuentas de cierre
  companiesAsResult           Company[] @relation("ResultAccount")
  companiesAsRetainedEarnings Company[] @relation("RetainedEarningsAccount")
  // Fase 17: Conciliación Bancaria
  bankAccount                 BankAccount?
  // Fase 13C Bloque 3: Snapshots de saldos por período
  periodSnapshots             PeriodSnapshot[]
  @@unique([companyId, code])
  @@unique([companyId, name])
}

model IGTFTransaction {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  amount        Decimal  @db.Decimal(19, 4)
  igtfRate      Decimal  @db.Decimal(5, 2)
  igtfAmount    Decimal  @db.Decimal(19, 4)
  currency      Currency @default(USD)
  concept       String
  createdAt     DateTime @default(now())
  createdBy     String
}

model Transaction {
  id          String         @id @default(cuid())
  number      String
  date        DateTime       @default(now())
  description String
  reference   String?
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  userId      String
  entries     JournalEntry[]
  createdAt   DateTime       @default(now())
  status      TransactionStatus @default(POSTED)
  type        TransactionType   @default(DIARIO)
  notes       String?
  voidedById  String?
  voidedBy    Transaction?      @relation("VoidRelation", fields: [voidedById], references: [id])
  voids       Transaction[]     @relation("VoidRelation")
  periodId    String?
  period      AccountingPeriod? @relation(fields: [periodId], references: [id])
  retenciones Retencion[]
  igtfTransactions IGTFTransaction[]
  invoices    Invoice[]
  // Fase 15: relaciones inversas para asientos de cierre
  fiscalYearCloseAsClosing       FiscalYearClose? @relation("ClosingTransaction")
  fiscalYearCloseAsAppropriation FiscalYearClose? @relation("AppropriationTransaction")
  // Fase 17B: conciliación bancaria
  bankTransactionMatches         BankTransaction[] @relation("BankTransactionMatch")

  @@unique([companyId, number])
}

model JournalEntry {
  id            String      @id @default(cuid())
  // Convención: positivo = Débito, negativo = Crédito
  amount        Decimal     @db.Decimal(19, 4)
  transactionId String
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  accountId     String
  account       Account     @relation(fields: [accountId], references: [id])
}

model User {
  id        String    @id
  name      String?
  email     String   @unique
  role      UserRole  @default(ACCOUNTANT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companies CompanyMember[]
}

model AuditLog {
  id         String   @id @default(cuid())
  entityId   String
  entityName String
  action     String
  userId     String
  oldValue   Json?
  newValue   Json
  createdAt  DateTime @default(now())
}

model AccountingPeriod {
  id          String       @id @default(cuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  year        Int
  month       Int          // 1-12
  status      PeriodStatus @default(OPEN)
  openedAt    DateTime     @default(now())
  closedAt    DateTime?
  openedBy    String       // userId
  closedBy    String?      // userId
  transactions Transaction[]
  invoices    Invoice[]
  // Fase 13C Bloque 3: Snapshots de saldos por período
  periodSnapshots PeriodSnapshot[]

  @@unique([companyId, year, month])
}

model Retencion {
  id               String          @id @default(cuid())
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  providerName     String
  providerRif      String
  invoiceNumber    String
  invoiceDate      DateTime
  invoiceAmount    Decimal         @db.Decimal(19, 4)
  taxBase          Decimal         @db.Decimal(19, 4)
  ivaAmount        Decimal         @db.Decimal(19, 4)
  ivaRetention     Decimal         @db.Decimal(19, 4)
  ivaRetentionPct  Decimal         @db.Decimal(5, 2)
  islrAmount       Decimal?        @db.Decimal(19, 4)
  islrRetentionPct Decimal?        @db.Decimal(5, 2)
  totalRetention   Decimal         @db.Decimal(19, 4)
  type             RetentionType
  status           RetentionStatus @default(PENDING)
  transactionId    String?
  transaction      Transaction?    @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  invoiceId        String?
  invoice          Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  voucherNumber    String?
  idempotencyKey   String          @unique
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  createdBy        String

  @@index([companyId])
  @@index([invoiceId])
  @@index([companyId, invoiceId])
}

model Invoice {
  id                   String            @id @default(cuid())
  companyId            String
  company              Company           @relation(fields: [companyId], references: [id])
  type                 InvoiceType
  docType              InvoiceDocType    @default(FACTURA)
  taxCategory          TaxCategory       @default(GRAVADA)
  invoiceNumber        String
  controlNumber        String?
  relatedDocNumber     String?
  importFormNumber     String?
  reportZStart         String?           // Reporte Z — número inicial
  reportZEnd           String?           // Reporte Z — número final
  date                 DateTime
  counterpartName      String
  counterpartRif       String
  ivaRetentionAmount   Decimal           @default(0) @db.Decimal(19, 4)
  ivaRetentionVoucher  String?
  ivaRetentionDate     DateTime?
  islrRetentionAmount  Decimal           @default(0) @db.Decimal(19, 4)
  igtfBase             Decimal           @default(0) @db.Decimal(19, 4)
  igtfAmount           Decimal           @default(0) @db.Decimal(19, 4)
  currency             Currency          @default(VES)
  exchangeRateId       String?
  exchangeRate         ExchangeRate?     @relation(fields: [exchangeRateId], references: [id], onDelete: Restrict)
  taxLines             InvoiceTaxLine[]
  retenciones          Retencion[]
  paymentRecords       PaymentRecord[]
  transactionId        String?
  transaction          Transaction?      @relation(fields: [transactionId], references: [id])
  periodId             String?
  period               AccountingPeriod? @relation(fields: [periodId], references: [id])
  idempotencyKey       String?           @unique
  deletedAt            DateTime?
  createdAt            DateTime          @default(now())
  createdBy            String
  // Fase 16: CxC/CxP
  dueDate              DateTime?
  totalAmountVes       Decimal?          @db.Decimal(19, 4)
  pendingAmount        Decimal?          @db.Decimal(19, 4)
  paymentStatus        InvoicePaymentStatus @default(UNPAID)
  invoicePayments      InvoicePayment[]

  @@unique([companyId, invoiceNumber, type])
  @@index([companyId, type, date])
  @@index([companyId, type, paymentStatus])
  @@index([companyId, type, dueDate])
}

model ControlNumberSequence {
  id          String      @id @default(cuid())
  companyId   String
  invoiceType InvoiceType
  lastNumber  Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, invoiceType])
  @@index([companyId])
}

model InvoiceTaxLine {
  id          String      @id @default(cuid())
  invoiceId   String
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  taxType     TaxLineType
  base        Decimal     @db.Decimal(19, 4)
  rate        Decimal     @db.Decimal(5, 2)
  amount      Decimal     @db.Decimal(19, 4)
}

model RetentionSequence {
  id         String   @id @default(cuid())
  companyId  String   @unique
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
}

// Tipo de cambio BCV oficial — 1 USD/EUR = X VES
model ExchangeRate {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  currency  Currency
  rate      Decimal  @db.Decimal(19, 6)
  date      DateTime @db.Date
  source    String   @default("BCV")
  createdAt DateTime @default(now())
  createdBy String
  invoices  Invoice[]

  paymentRecords  PaymentRecord[]
  invoicePayments InvoicePayment[]

  @@unique([companyId, currency, date])
  @@index([companyId, currency, date])
}

// Registro de pagos por medio de pago digital (PagoMóvil, Zelle, Cashea, etc.)
model PaymentRecord {
  id               String        @id @default(cuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoiceId        String?
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  method           PaymentMethod
  amountVes        Decimal       @db.Decimal(19, 4)    // siempre en VES
  currency         Currency      @default(VES)          // moneda del pago original
  amountOriginal   Decimal?      @db.Decimal(19, 4)    // monto en moneda original (Zelle USD)
  exchangeRateId   String?
  exchangeRate     ExchangeRate? @relation(fields: [exchangeRateId], references: [id])
  // PagoMóvil
  referenceNumber  String?
  originBank       String?
  destBank         String?
  // Cashea
  commissionPct    Decimal?      @db.Decimal(5, 2)
  commissionAmount Decimal?      @db.Decimal(19, 4)
  // IGTF (Zelle & Cashea USD)
  igtfAmount       Decimal?      @db.Decimal(19, 4)
  date             DateTime
  notes            String?
  createdAt        DateTime      @default(now())
  createdBy        String
  // Fase 17B: conciliación bancaria
  bankTransactions BankTransaction[]

  @@index([companyId])
  @@index([invoiceId])
  @@index([companyId, date])
}

// ─── Fase 15: Cierre de Ejercicio Económico ────────────────────────────────────
// Representa el cierre anual de cuentas de resultado (VEN-NIF).
// Existencia de registro = ejercicio cerrado (@@unique enforces idempotency).
model FiscalYearClose {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  year        Int

  closedAt    DateTime @default(now())
  closedBy    String   // userId Clerk

  // Asiento 1: cierre de cuentas de resultado (OBLIGATORIO)
  closingTransactionId       String      @unique
  closingTransaction         Transaction @relation("ClosingTransaction", fields: [closingTransactionId], references: [id], onDelete: Restrict)

  // Asiento 2: apropiación resultado → patrimonio (OPCIONAL — post-AGO)
  appropriationTransactionId String?     @unique
  appropriationTransaction   Transaction? @relation("AppropriationTransaction", fields: [appropriationTransactionId], references: [id], onDelete: Restrict)

  // Snapshot inmutable de montos al momento del cierre
  totalRevenue   Decimal @db.Decimal(19, 4)
  totalExpenses  Decimal @db.Decimal(19, 4)
  netResult      Decimal @db.Decimal(19, 4) // positivo = ganancia, negativo = pérdida

  createdAt   DateTime @default(now())

  @@unique([companyId, year])
  @@index([companyId])
}

// ─── Fase 16: Cartera CxC/CxP ─────────────────────────────────────────────────
// Pago de cancelación de cartera — semánticamente distinto de PaymentRecord
// (medios de pago digitales). InvoicePayment representa la cancelación VEN-NIF
// de una cuenta por cobrar o por pagar.
model InvoicePayment {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amount          Decimal       @db.Decimal(19, 4)   // monto aplicado en VES
  currency        Currency      @default(VES)
  amountOriginal  Decimal?      @db.Decimal(19, 4)   // monto en moneda original si != VES
  exchangeRateId  String?
  exchangeRate    ExchangeRate? @relation(fields: [exchangeRateId], references: [id], onDelete: Restrict)
  method          PaymentMethod
  referenceNumber String?
  originBank      String?
  destBank        String?
  commissionPct   Decimal?      @db.Decimal(5, 4)
  igtfAmount      Decimal?      @db.Decimal(19, 4)
  date            DateTime
  notes           String?
  createdBy       String
  createdAt       DateTime      @default(now())
  idempotencyKey  String        @unique
  deletedAt       DateTime?
  deletedBy       String?
  // Fase 17: Conciliación Bancaria
  bankTransactions BankTransaction[]

  @@index([invoiceId])
  @@index([companyId, date])
}

// ─── Fase 17: Conciliación Bancaria ───────────────────────────────────────────

enum BankTransactionType {
  CREDIT   // Entrada de dinero (abono)
  DEBIT    // Salida de dinero (cargo)
}

enum BankStatementStatus {
  OPEN     // Estado de trabajo activo
  CLOSED   // Conciliado / cerrado
}

model BankAccount {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  accountId       String   @unique
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  name            String
  bankName        String
  accountNumber   String?
  currency        Currency @default(VES)
  closingBalance  Decimal  @db.Decimal(19, 4) @default(0)
  isActive        Boolean  @default(true)
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  createdBy       String

  statements  BankStatement[]

  @@index([companyId])
}

model BankStatement {
  id              String              @id @default(cuid())
  bankAccountId   String
  bankAccount     BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  periodStart     DateTime            @db.Date
  periodEnd       DateTime            @db.Date
  openingBalance  Decimal             @db.Decimal(19, 4)
  closingBalance  Decimal             @db.Decimal(19, 4)
  status          BankStatementStatus @default(OPEN)
  importedAt      DateTime            @default(now())
  importedBy      String
  deletedAt       DateTime?

  transactions    BankTransaction[]

  @@index([bankAccountId])
}

model BankTransaction {
  id                    String              @id @default(cuid())
  statementId           String
  statement             BankStatement       @relation(fields: [statementId], references: [id], onDelete: Restrict)
  date                  DateTime            @db.Date
  description           String
  type                  BankTransactionType
  amount                Decimal             @db.Decimal(19, 4)
  reference             String?
  isReconciled          Boolean             @default(false)
  // Match tipo 1: InvoicePayment — cancelación cartera CxC/CxP (Fase 17)
  matchedPaymentId      String?
  matchedPayment        InvoicePayment?     @relation(fields: [matchedPaymentId], references: [id], onDelete: Restrict)
  // Match tipo 2: Transaction — asiento de libro mayor (Fase 17B)
  matchedTransactionId  String?
  matchedTransaction    Transaction?        @relation("BankTransactionMatch", fields: [matchedTransactionId], references: [id], onDelete: Restrict)
  // Match tipo 3: PaymentRecord — pago multi-medio digital (Fase 17B)
  matchedPaymentRecordId  String?
  matchedPaymentRecord    PaymentRecord?    @relation(fields: [matchedPaymentRecordId], references: [id], onDelete: Restrict)
  matchedAt             DateTime?
  matchedBy             String?
  deletedAt             DateTime?

  createdAt             DateTime            @default(now())

  @@index([statementId])
  @@index([matchedPaymentId])
  @@index([matchedTransactionId])
  @@index([matchedPaymentRecordId])
}

// ─── Fase 13C Bloque 3: Snapshots de Saldos por Período ───────────────────────
// Saldo precalculado por cuenta al cierre de cada período contable.
// Permite que reportes (Balance General, Estado de Resultados) lean este snapshot
// en lugar de recalcular todos los asientos históricos en cada request.
// Nota: ExchangeRate (Fase 14) cubre las tasas históricas — no se necesita
// un modelo separado ExchangeRateSnapshot.
model PeriodSnapshot {
  id              String           @id @default(cuid())
  companyId       String
  periodId        String
  accountId       String
  balanceVes      Decimal          @db.Decimal(19,4)
  balanceOriginal Decimal?         @db.Decimal(19,4)
  currency        Currency         @default(VES)
  snapshotAt      DateTime         @default(now())

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  period   AccountingPeriod @relation(fields: [periodId], references: [id], onDelete: Restrict)
  account  Account          @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([periodId, accountId])
  @@index([companyId, periodId])
}
