datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum AccountType {
  ASSET
  CONTRA_ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum CompanyStatus {
  ACTIVE
  ARCHIVED
}

enum CompanyPlan {
  FREE
  PRO
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum UserRole {
  OWNER // Propietario — creador de la empresa, acceso total
  ADMIN // Administrador — acceso total, asignado por el propietario
  ACCOUNTANT // Contador — módulos contables
  ADMINISTRATIVE // Administrativo — módulos operativos (Fase 28+)
  VIEWER // Observador — solo lectura en su área
  SENIAT // Auditor fiscal SENIAT — solo lectura, acceso a informes de auditoría (ADR-019)
}

enum TransactionStatus {
  POSTED // Contabilizado — inmutable
  VOIDED // Anulado con contrapartida
}

enum TransactionType {
  DIARIO // Operaciones normales manuales
  APERTURA // Inicio del periodo
  AJUSTE // Correcciones al cierre
  CIERRE // Cierre del periodo
  COBRO // GL auto-posting de cobro CxC (ADR-030 audit Riesgo-9 Art.33 COT)
  PAGO // GL auto-posting de pago CxP / lote A/P (ADR-030 audit Riesgo-9 Art.33 COT)
}

enum RetentionType {
  IVA
  ISLR
  AMBAS
}

enum RetentionStatus {
  PENDING
  ISSUED
  ENTERADO // Enterada ante SENIAT — con asiento contable de pago
  VOIDED
}

enum InvoiceType {
  SALE
  PURCHASE
}

enum InvoiceDocType {
  FACTURA
  NOTA_DEBITO
  NOTA_CREDITO
  REPORTE_Z
  RESUMEN_VENTAS
  PLANILLA_IMPORTACION
  OTRO
}

enum TaxCategory {
  GRAVADA
  EXENTA
  EXONERADA
  NO_SUJETA
  IMPORTACION
}

enum TaxLineType {
  IVA_GENERAL
  IVA_REDUCIDO
  IVA_ADICIONAL
  EXENTO
}

// Alícuota aplicable a una línea de factura (InvoiceLine) — distinta de TaxLineType
// que es el agregado fiscal SENIAT. Ver ADR-024 D-1.3 para la tabla de mapeo.
enum IvaLineRate {
  EXENTO // 0% — sin IVA
  REDUCIDO_8 // 8% — alícuota reducida (Providencia 0057)
  GENERAL_16 // 16% — alícuota general estándar
  ADICIONAL_31 // 31% — 16% general + 15% adicional lujo (Art. 61 LIVA)
}

enum Currency {
  VES
  USD
  EUR
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  PAGOMOVIL
  ZELLE
  CASHEA
}

enum InvoicePaymentStatus {
  UNPAID // Sin pagos
  PARTIAL // Pagado parcialmente
  PAID // Cancelado totalmente
  VOIDED // Factura anulada (deletedAt no nulo)
}

model Company {
  id                         String                      @id @default(cuid())
  name                       String
  transactions               Transaction[]
  periods                    AccountingPeriod[]
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  rif                        String?                     @unique // RIF para Venezuela
  // Q3-5 Multi-país: ISO 3166-1 alpha-3 — fuente de verdad en src/lib/tax-config.ts
  country                    String                      @default("VEN")
  address                    String?
  members                    CompanyMember[]
  accounts                   Account[]
  status                     CompanyStatus               @default(ACTIVE)
  plan                       CompanyPlan                 @default(FREE)
  isSpecialContributor       Boolean                     @default(false)
  // Datos SENIAT — PA-121 (Forma 30, Libro Mayor, reportes fiscales)
  telefono                   String?
  email                      String?
  ciiu                       String?
  actividad                  String?
  retenciones                Retencion[]
  igtfTransactions           IGTFTransaction[]
  invoices                   Invoice[]
  controlNumberSequences     ControlNumberSequence[]
  retentionSequences         RetentionSequence[]
  exchangeRates              ExchangeRate[]
  paymentRecords             PaymentRecord[]
  // ADR-029: Adjuntos de comprobante de pago
  paymentAttachments         PaymentAttachment[]
  // Fase 16: Cartera CxC/CxP
  paymentTermDays            Int                         @default(30)
  invoicePayments            InvoicePayment[]
  // Fase 17: Conciliación Bancaria
  bankAccounts               BankAccount[]
  // Fase 13D: companyId desnormalizado en BankTransaction para RLS
  bankTransactions           BankTransaction[]           @relation("BankTransactionCompany")
  // Fase 15: Cierre de ejercicio económico
  resultAccountId            String?
  resultAccount              Account?                    @relation("ResultAccount", fields: [resultAccountId], references: [id], onDelete: Restrict)
  retainedEarningsAccountId  String?
  retainedEarningsAccount    Account?                    @relation("RetainedEarningsAccount", fields: [retainedEarningsAccountId], references: [id], onDelete: Restrict)
  fiscalYearCloses           FiscalYearClose[]
  // Fase 13C Bloque 3: Snapshots de saldos por período
  periodSnapshots            PeriodSnapshot[]
  // Fase 21: Activos Fijos
  fixedAssets                FixedAsset[]
  fixedAssetINPCRestatements FixedAssetINPCRestatement[] // N3
  // Fase 22: Ajuste por Inflación (INPC / VEN-NIF 3)
  inflationBaseYear          Int?
  inflationBaseMonth         Int?
  inpcRates                  INPCRate[]
  inflationAdjustments       InflationAdjustment[]
  // Fase 30: Exportación Masiva
  exportJobs                 ExportJob[]
  // Fase 28D: Inventario
  inventoryItems             InventoryItem[]
  inventoryMovements         InventoryMovement[]
  // Fase 28: Compras y Ventas
  quotations                 Quotation[]
  orders                     Order[]
  orderNumberSequences       OrderNumberSequence[]
  // Fase NOM-A: Configuración de Nómina
  payrollConfig              PayrollConfig?
  // Ítem 72: Histórico de topes legales (salario mínimo, UT)
  legalThresholds            LegalThreshold[]
  // Fase NOM-B: Empleados y Conceptos
  employees                  Employee[]
  payrollConcepts            PayrollConcept[]
  publicHolidays             PublicHoliday[]
  absenceTypes               AbsenceType[]
  // Fase NOM-C: Motor de Cálculo de Nómina
  payrollRuns                PayrollRun[]
  // Fase NOM-D: Prestaciones Sociales, Vacaciones, Utilidades, Liquidación
  bcvBenefitRates            BcvBenefitRate[]
  benefitBalances            BenefitBalance[]
  benefitAccrualLines        BenefitAccrualLine[]
  benefitAdvances            BenefitAdvance[]
  vacationRecords            VacationRecord[]
  profitSharingRecords       ProfitSharingRecord[]
  terminations               Termination[]
  // Fase 35A: Vendor / Customer
  vendors                    Vendor[]
  customers                  Customer[]
  // ADR-028: Grupos de contactos
  vendorGroups               VendorGroup[]
  customerGroups             CustomerGroup[]
  // Q3-2: CRM básico — notas de interacción
  contactNotes               ContactNote[]
  // Fase 35H: PA-121 Outbox
  seniatSubmissions          SeniatSubmission[]
  // Fase 35I: Firma Digital
  certificate                CompanyCertificate?
  // Fase 35F: Unidades de Medida Múltiples
  inventoryItemUnits         InventoryItemUnit[]
  // Fase 35G: Lot/Serial Tracking
  inventoryLots              InventoryLot[]
  inventorySerials           InventorySerial[]
  // Fase 36C: Distribución de Pagos A/P
  paymentBatches             PaymentBatch[]
  // Sprint 3: Suscripciones y Facturación
  subscription               Subscription?
  referredSubscriptions      Subscription[]              @relation("SubscriptionReferral")
  // Fase 37A: configuración operacional de empresa
  settings                   CompanySettings?
  // Fase 37A: líneas de factura (para multi-tenant IDOR check)
  invoiceLines               InvoiceLine[]
  // Fase 37B: Módulo Gastos
  expenses                   Expense[]
  expenseCategories          ExpenseCategory[]
  // Fase 36D: Distribución de Ingresos Multidestinatario (ADR-023)
  incomeDistributions        IncomeDistribution[]        @relation("IncomeDistributions")
  incomeDistributionLines    IncomeDistributionLine[]    @relation("IncomeDistributionRecipients")
  // Fase 35D: Caja Chica (Fondo Fijo)
  cajaCajas                  CajaCaja[]
  // Permisos granulares por rol (grants adicionales al rol base)
  rolePermissions            RolePermission[]
  employeeLoans              EmployeeLoan[]
  // Q3-3: Presupuestos y proyecciones
  budgets                    Budget[]
  budgetLines                BudgetLine[]
  // Fase 39: Facturación Digital PA-102 (ADR-031)
  digitalInvoiceProvider     DigitalInvoiceProviderType  @default(NONE)
  digitalInvoiceApiKeyEnc    String? // AES-256-GCM — nunca exponer al cliente
}

model CompanyMember {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole @default(ACCOUNTANT)
  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

model RolePermission {
  id        String   @id @default(cuid())
  companyId String
  role      UserRole
  module    String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, role, module])
  @@index([companyId])
}

model Account {
  id                                   String                   @id @default(cuid())
  name                                 String
  code                                 String
  type                                 AccountType
  description                          String?
  // VEN-NIF 3: true = Caja/Bancos/CxC/CxP — no se reexpresa por INPC; genera REPOMO
  isMonetary                           Boolean                  @default(false)
  // VEN-NIF BA-10 / IAS 1: true = corriente (realizable/exigible en ≤12 meses)
  isCurrent                            Boolean                  @default(false)
  companyId                            String
  company                              Company                  @relation(fields: [companyId], references: [id])
  journalEntries                       JournalEntry[]
  deletedAt                            DateTime?
  createdAt                            DateTime                 @default(now())
  updatedAt                            DateTime                 @updatedAt
  // Fase 15: relaciones inversas para cuentas de cierre
  companiesAsResult                    Company[]                @relation("ResultAccount")
  companiesAsRetainedEarnings          Company[]                @relation("RetainedEarningsAccount")
  // Fase 17: Conciliación Bancaria
  bankAccount                          BankAccount?
  // Fase 13C Bloque 3: Snapshots de saldos por período
  periodSnapshots                      PeriodSnapshot[]
  // Fase 21: Activos Fijos
  fixedAssetsAsAsset                   FixedAsset[]             @relation("FixedAssetAccount")
  fixedAssetsAsDepreciation            FixedAsset[]             @relation("DepreciationExpenseAccount")
  fixedAssetsAsAccDepreciation         FixedAsset[]             @relation("AccumulatedDepreciationAccount")
  // Fase 22: Ajuste por Inflación
  inflationAdjustments                 InflationAdjustment[]
  // Fase 28D: Inventario
  inventoryItems                       InventoryItem[]          @relation("InventoryItemAccount")
  inventoryItemsAsCogs                 InventoryItem[]          @relation("CogsAccount")
  inventoryMovementsAsCounterpart      InventoryMovement[]      @relation("InventoryMovementCounterpart")
  // Fase NOM-C: Cuentas contables de nómina
  payrollConfigsAsExpense              PayrollConfig[]          @relation("PayrollExpenseAccount")
  payrollConfigsAsPayable              PayrollConfig[]          @relation("PayrollPayableAccount")
  payrollConfigsAsIvss                 PayrollConfig[]          @relation("PayrollIvssPayable")
  payrollConfigsAsFaov                 PayrollConfig[]          @relation("PayrollFaovPayable")
  payrollConfigsAsInces                PayrollConfig[]          @relation("PayrollIncesPayable")
  payrollConfigsAsRpe                  PayrollConfig[]          @relation("PayrollRpePayable")
  // Fase NOM-D: cuentas de prestaciones
  payrollConfigsAsBenefitsExpense      PayrollConfig[]          @relation("PayrollBenefitsExpense")
  payrollConfigsAsBenefitsPayable      PayrollConfig[]          @relation("PayrollBenefitsPayable")
  payrollConfigsAsVacationPayable      PayrollConfig[]          @relation("PayrollVacationPayable")
  payrollConfigsAsProfitPayable        PayrollConfig[]          @relation("PayrollProfitPayable")
  payrollConfigsAsLoanReceivable       PayrollConfig[]          @relation("PayrollLoanReceivable")
  payrollConfigsAsDisbursementBank     PayrollConfig[]          @relation("PayrollDisbursementBank")
  // F-02/F-03: Cuentas aportes patronales
  payrollConfigsAsIvssPatronal         PayrollConfig[]          @relation("PayrollIvssPatronal")
  payrollConfigsAsIncesPatronal        PayrollConfig[]          @relation("PayrollIncesPatronal")
  payrollConfigsAsFaovPatronal         PayrollConfig[]          @relation("PayrollFaovPatronal")
  payrollConfigsAsRpePatronal          PayrollConfig[]          @relation("PayrollRpePatronal")
  // Fase 37B: Módulo Gastos
  expensesAsAccount                    Expense[]                @relation("ExpenseAccount")
  expenseCategoryDefaults              ExpenseCategory[]        @relation("ExpenseCategoryAccount")
  // ADR-026: Configuración GL para causación automática de facturas
  companySettingsAsAR                  CompanySettings[]        @relation("SettingsARAccount")
  companySettingsAsAP                  CompanySettings[]        @relation("SettingsAPAccount")
  companySettingsAsSales               CompanySettings[]        @relation("SettingsSalesAccount")
  companySettingsAsPurchaseExpense     CompanySettings[]        @relation("SettingsPurchaseExpenseAccount")
  companySettingsAsInventory           CompanySettings[]        @relation("SettingsInventoryAccount")
  companySettingsAsIVADF               CompanySettings[]        @relation("SettingsIVADFAccount")
  companySettingsAsIVACF               CompanySettings[]        @relation("SettingsIVACFAccount")
  // ADR-027: Diferencial cambiario NIC 21 / VEN-NIF BA-5
  companySettingsAsFxGain              CompanySettings[]        @relation("SettingsFxGainAccount")
  companySettingsAsFxLoss              CompanySettings[]        @relation("SettingsFxLossAccount")
  // GAP-03 auditoría SENIAT: Retenciones IVA por Pagar — split CR en asientos de compra con retención
  companySettingsAsIVARetentionPayable CompanySettings[]        @relation("SettingsIVARetentionPayableAccount")
  // Fase 36D: Distribución de Ingresos
  incomeDistributionOrigins            IncomeDistribution[]     @relation("IncomeDistributionOrigin")
  incomeDistributionLineAccounts       IncomeDistributionLine[] @relation("IncomeDistributionLineAccounts")
  // Fase 35D: Caja Chica
  cajaCajas                            CajaCaja[]               @relation("CajaCajaAccount")
  cajaCajaMovements                    CajaCajaMovement[]       @relation("CajaCajaExpenseAccount")
  // ADR-030: cuenta IGTF por Pagar en configuración GL
  companySettingsAsIGTFPayable         CompanySettings[]        @relation("SettingsIGTFPayableAccount")
  companySettingsAsIVARetReceivable    CompanySettings[]        @relation("SettingsIVARetentionReceivableAccount")
  // Q3-3: Presupuestos
  budgetLines                          BudgetLine[]

  @@unique([companyId, code])
  @@unique([companyId, name])
}

model IGTFTransaction {
  id            String       @id @default(cuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id])
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  amount        Decimal      @db.Decimal(19, 4)
  igtfRate      Decimal      @db.Decimal(5, 2)
  igtfAmount    Decimal      @db.Decimal(19, 4)
  currency      Currency     @default(USD)
  concept       String
  createdAt     DateTime     @default(now())
  createdBy     String
}

model Transaction {
  id                             String                 @id @default(cuid())
  number                         String
  date                           DateTime               @default(now())
  description                    String
  reference                      String?
  companyId                      String
  company                        Company                @relation(fields: [companyId], references: [id])
  userId                         String
  entries                        JournalEntry[]
  createdAt                      DateTime               @default(now())
  status                         TransactionStatus      @default(POSTED)
  type                           TransactionType        @default(DIARIO)
  notes                          String?
  voidedById                     String?
  voidedBy                       Transaction?           @relation("VoidRelation", fields: [voidedById], references: [id])
  voids                          Transaction[]          @relation("VoidRelation")
  periodId                       String?
  period                         AccountingPeriod?      @relation(fields: [periodId], references: [id])
  retenciones                    Retencion[]
  igtfTransactions               IGTFTransaction[]
  invoices                       Invoice[]
  // Fase 15: relaciones inversas para asientos de cierre
  fiscalYearCloseAsClosing       FiscalYearClose?       @relation("ClosingTransaction")
  fiscalYearCloseAsAppropriation FiscalYearClose?       @relation("AppropriationTransaction")
  // Fase 17B: conciliación bancaria
  bankTransactionMatches         BankTransaction[]      @relation("BankTransactionMatch")
  // Fase 21: Activos Fijos — asiento de depreciación generado
  depreciationEntry              DepreciationEntry?
  // Fase 22: Ajuste por Inflación
  inflationAdjustments           InflationAdjustment[]
  // Fase 28D: Inventario
  inventoryMovement              InventoryMovement?
  // Fase NOM-C: Motor de Nómina
  payrollRun                     PayrollRun?
  // Fase NOM-D: Beneficios laborales
  benefitAccrualLine             BenefitAccrualLine?
  benefitAdvance                 BenefitAdvance?
  vacationRecord                 VacationRecord?
  profitSharingRecord            ProfitSharingRecord?
  termination                    Termination?
  // Fase 37B: Módulo Gastos
  expense                        Expense?
  // Fase 36D: Distribución de Ingresos
  incomeDistribution             IncomeDistribution?
  // Fase 35D: Caja Chica
  cajaCajaDeposit                CajaCajaDeposit?
  cajaCajaReimbursement          CajaCajaReimbursement?
  // ADR-030: asientos GL generados por pagos
  paymentRecordGL                PaymentRecord?         @relation("PaymentRecordGLTransaction")
  paymentBatchGL                 PaymentBatch?          @relation("PaymentBatchGLTransaction")

  @@unique([companyId, number])
}

model JournalEntry {
  id            String      @id @default(cuid())
  // Convención: positivo = Débito, negativo = Crédito
  amount        Decimal     @db.Decimal(19, 4)
  description   String?
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  accountId     String
  account       Account     @relation(fields: [accountId], references: [id])
}

model User {
  id        String          @id
  name      String?
  email     String          @unique
  role      UserRole        @default(ACCOUNTANT)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  companies CompanyMember[]
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String?
  entityId   String
  entityName String
  action     String
  userId     String
  oldValue   Json?
  newValue   Json
  ipAddress  String? // PA-121 trazabilidad de red (ADR-019 D-2)
  userAgent  String? // PA-121 trazabilidad de red (ADR-019 D-2)
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, entityName, createdAt(sort: Desc)])
}

model AccountingPeriod {
  id              String           @id @default(cuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  year            Int
  month           Int // 1-12
  status          PeriodStatus     @default(OPEN)
  openedAt        DateTime         @default(now())
  closedAt        DateTime?
  openedBy        String // userId
  closedBy        String? // userId
  transactions    Transaction[]
  invoices        Invoice[]
  // Fase 13C Bloque 3: Snapshots de saldos por período
  periodSnapshots PeriodSnapshot[]

  @@unique([companyId, year, month])
}

model Retencion {
  id                String          @id @default(cuid())
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  providerName      String
  providerRif       String
  invoiceNumber     String
  invoiceDate       DateTime
  invoiceAmount     Decimal         @db.Decimal(19, 4)
  taxBase           Decimal         @db.Decimal(19, 4)
  ivaAmount         Decimal         @db.Decimal(19, 4)
  ivaRetention      Decimal         @db.Decimal(19, 4)
  ivaRetentionPct   Decimal         @db.Decimal(5, 2)
  islrAmount        Decimal?        @db.Decimal(19, 4)
  islrRetentionPct  Decimal?        @db.Decimal(5, 2)
  incesAmount       Decimal?        @db.Decimal(19, 4) // INCES 2% — Ley INCES Art. 14
  incesRetentionPct Decimal?        @db.Decimal(5, 2)
  fatAmount         Decimal?        @db.Decimal(19, 4) // FAT 0.75%
  fatRetentionPct   Decimal?        @db.Decimal(5, 2)
  totalRetention    Decimal         @db.Decimal(19, 4)
  type              RetentionType
  status            RetentionStatus @default(PENDING)
  transactionId     String?
  transaction       Transaction?    @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  invoiceId         String?
  invoice           Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  voucherNumber     String?
  idempotencyKey    String          @unique
  enteradoAt        DateTime?
  enteradoBy        String? // userId que ejecutó el enteramiento
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  createdBy         String

  @@index([companyId])
  @@index([invoiceId])
  @@index([companyId, invoiceId])
}

model Invoice {
  id                              String               @id @default(cuid())
  companyId                       String
  company                         Company              @relation(fields: [companyId], references: [id])
  type                            InvoiceType
  docType                         InvoiceDocType       @default(FACTURA)
  taxCategory                     TaxCategory          @default(GRAVADA)
  invoiceNumber                   String
  controlNumber                   String?
  relatedDocNumber                String?
  importFormNumber                String?
  reportZStart                    String? // Reporte Z — número inicial
  reportZEnd                      String? // Reporte Z — número final
  date                            DateTime
  counterpartName                 String
  counterpartRif                  String
  // H-1: Art. 57 Ley IVA + Art. 13 Prov. 00071 — snapshot dirección fiscal
  counterpartAddress              String?
  // H-2: Prov. 0049 — snapshot metadato CE para precisión histórica de retenciones
  counterpartIsSpecialContributor Boolean              @default(false)
  ivaRetentionAmount              Decimal              @default(0) @db.Decimal(19, 4)
  ivaRetentionVoucher             String?
  ivaRetentionDate                DateTime?
  islrRetentionAmount             Decimal              @default(0) @db.Decimal(19, 4)
  igtfBase                        Decimal              @default(0) @db.Decimal(19, 4)
  igtfAmount                      Decimal              @default(0) @db.Decimal(19, 4)
  currency                        Currency             @default(VES)
  exchangeRateId                  String?
  exchangeRate                    ExchangeRate?        @relation(fields: [exchangeRateId], references: [id], onDelete: Restrict)
  taxLines                        InvoiceTaxLine[]
  retenciones                     Retencion[]
  paymentRecords                  PaymentRecord[]
  transactionId                   String?
  transaction                     Transaction?         @relation(fields: [transactionId], references: [id])
  periodId                        String?
  period                          AccountingPeriod?    @relation(fields: [periodId], references: [id])
  idempotencyKey                  String?              @unique
  deletedAt                       DateTime?
  createdAt                       DateTime             @default(now())
  createdBy                       String
  // Fase 16: CxC/CxP
  dueDate                         DateTime?
  totalAmountVes                  Decimal?             @db.Decimal(19, 4)
  pendingAmount                   Decimal?             @db.Decimal(19, 4)
  paymentStatus                   InvoicePaymentStatus @default(UNPAID)
  invoicePayments                 InvoicePayment[]
  // Fase 23C: NC/ND Workflow (Reglamento IVA Art. 58)
  relatedInvoiceId                String?
  relatedInvoice                  Invoice?             @relation("CreditDebitNotes", fields: [relatedInvoiceId], references: [id], onDelete: Restrict)
  creditDebitNotes                Invoice[]            @relation("CreditDebitNotes")
  // Fase 28D: Inventario
  inventoryMovements              InventoryMovement[]
  // Fase 28: Compras y Ventas
  orderId                         String?              @unique
  order                           Order?               @relation(fields: [orderId], references: [id], onDelete: Restrict)
  // Fase 35A: Vendor / Customer
  vendorId                        String?
  vendor                          Vendor?              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  customerId                      String?
  customer                        Customer?            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  // Fase 35H: PA-121 Outbox
  seniatSubmission                SeniatSubmission?
  // Fase 36C: Distribución de Pagos A/P
  paymentBatchLines               PaymentBatchLine[]
  // Fase 37A: Líneas de detalle de factura
  lines                           InvoiceLine[]
  // Fase 39: Facturación Digital PA-102 (ADR-031)
  controlNumberSource             ControlNumberSource  @default(INTERNAL)
  qrCodeData                      String? // URL o base64 del QR del proveedor
  providerReferenceId             String? // ID de la imprenta para reconciliación
  isContingency                   Boolean              @default(false)

  @@unique([companyId, invoiceNumber, type])
  @@index([companyId, type, date])
  @@index([companyId, type, paymentStatus])
  @@index([companyId, type, dueDate])
  @@index([relatedInvoiceId])
}

model ControlNumberSequence {
  id          String      @id @default(cuid())
  companyId   String
  invoiceType InvoiceType
  lastNumber  Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, invoiceType])
  @@index([companyId])
}

model InvoiceTaxLine {
  id          String      @id @default(cuid())
  invoiceId   String
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  taxType     TaxLineType
  base        Decimal     @db.Decimal(19, 4)
  rate        Decimal     @db.Decimal(5, 2)
  amount      Decimal     @db.Decimal(19, 4)
  description String?
}

model RetentionSequence {
  id         String   @id @default(cuid())
  companyId  String   @unique
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
}

// Tipo de cambio BCV oficial — 1 USD/EUR = X VES
model ExchangeRate {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  currency  Currency
  rate      Decimal   @db.Decimal(19, 6)
  date      DateTime  @db.Date
  source    String    @default("BCV")
  createdAt DateTime  @default(now())
  createdBy String
  invoices  Invoice[]

  paymentRecords  PaymentRecord[]
  invoicePayments InvoicePayment[]
  paymentBatches  PaymentBatch[]

  @@unique([companyId, currency, date])
  @@index([companyId, currency, date])
}

// Registro de pagos por medio de pago digital (PagoMóvil, Zelle, Cashea, etc.)
model PaymentRecord {
  id                 String              @id @default(cuid())
  companyId          String
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoiceId          String?
  invoice            Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  method             PaymentMethod
  amountVes          Decimal             @db.Decimal(19, 4) // siempre en VES
  currency           Currency            @default(VES) // moneda del pago original
  amountOriginal     Decimal?            @db.Decimal(19, 4) // monto en moneda original (Zelle USD)
  exchangeRateId     String?
  exchangeRate       ExchangeRate?       @relation(fields: [exchangeRateId], references: [id])
  // PagoMóvil / Transferencia
  referenceNumber    String?
  originBank         String?
  destBank           String?
  // PagoMóvil — trazabilidad bancaria (#1/#16 — 20260525)
  senderPhone        String? // teléfono del emisor
  destPhone          String? // teléfono del receptor
  // Cashea
  commissionPct      Decimal?            @db.Decimal(5, 2)
  commissionAmount   Decimal?            @db.Decimal(19, 4)
  // IGTF (Zelle & Cashea USD)
  igtfAmount         Decimal?            @db.Decimal(19, 4)
  // Riesgo-6 auditoría: IVA retenido por el cliente CE (Prov. 0049 75%/100%)
  // amountVes = cash neto recibido; ivaRetentionAmount = IVA retenido → Dr. IVA Ret. x Cobrar
  ivaRetentionAmount Decimal?            @default(0) @db.Decimal(19, 4)
  date               DateTime
  notes              String?
  // Anulación (#14 — 20260525)
  deletedAt          DateTime?
  voidReason         String?
  createdAt          DateTime            @default(now())
  createdBy          String
  // Fase 17B: conciliación bancaria
  bankTransactions   BankTransaction[]
  // ADR-029: Adjuntos de comprobante de pago
  attachments        PaymentAttachment[]
  // ADR-030: FK a cuenta bancaria para GL auto-posting (nullable — degradación graceful)
  bankAccountId      String?
  bankAccount        BankAccount?        @relation("PaymentRecordBankAccount", fields: [bankAccountId], references: [id], onDelete: Restrict)
  // ADR-030: FK al Transaction generado por GL auto-posting (null hasta que se genere el asiento)
  glTransactionId    String?             @unique
  glTransaction      Transaction?        @relation("PaymentRecordGLTransaction", fields: [glTransactionId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([invoiceId])
  @@index([companyId, date])
  @@index([companyId, bankAccountId])
}

// ─── Fase 15: Cierre de Ejercicio Económico ────────────────────────────────────
// Representa el cierre anual de cuentas de resultado (VEN-NIF).
// Existencia de registro = ejercicio cerrado (@@unique enforces idempotency).
model FiscalYearClose {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  year      Int

  closedAt DateTime @default(now())
  closedBy String // userId Clerk

  // Asiento 1: cierre de cuentas de resultado (OBLIGATORIO)
  closingTransactionId String      @unique
  closingTransaction   Transaction @relation("ClosingTransaction", fields: [closingTransactionId], references: [id], onDelete: Restrict)

  // Asiento 2: apropiación resultado → patrimonio (OPCIONAL — post-AGO)
  appropriationTransactionId String?      @unique
  appropriationTransaction   Transaction? @relation("AppropriationTransaction", fields: [appropriationTransactionId], references: [id], onDelete: Restrict)

  // Snapshot inmutable de montos al momento del cierre
  totalRevenue  Decimal @db.Decimal(19, 4)
  totalExpenses Decimal @db.Decimal(19, 4)
  netResult     Decimal @db.Decimal(19, 4) // positivo = ganancia, negativo = pérdida

  createdAt DateTime @default(now())

  @@unique([companyId, year])
  @@index([companyId])
}

// ─── Fase 16: Cartera CxC/CxP ─────────────────────────────────────────────────
// Pago de cancelación de cartera — semánticamente distinto de PaymentRecord
// (medios de pago digitales). InvoicePayment representa la cancelación VEN-NIF
// de una cuenta por cobrar o por pagar.
model InvoicePayment {
  id               String            @id @default(cuid())
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoiceId        String
  invoice          Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amount           Decimal           @db.Decimal(19, 4) // monto aplicado en VES
  currency         Currency          @default(VES)
  amountOriginal   Decimal?          @db.Decimal(19, 4) // monto en moneda original si != VES
  exchangeRateId   String?
  exchangeRate     ExchangeRate?     @relation(fields: [exchangeRateId], references: [id], onDelete: Restrict)
  method           PaymentMethod
  referenceNumber  String?
  originBank       String?
  destBank         String?
  commissionPct    Decimal?          @db.Decimal(5, 4)
  igtfAmount       Decimal?          @db.Decimal(19, 4)
  date             DateTime
  notes            String?
  createdBy        String
  createdAt        DateTime          @default(now())
  idempotencyKey   String            @unique
  deletedAt        DateTime?
  deletedBy        String?
  // Fase 17: Conciliación Bancaria
  bankTransactions BankTransaction[]

  @@index([invoiceId])
  @@index([companyId, date])
}

// ─── Fase 17: Conciliación Bancaria ───────────────────────────────────────────

enum BankTransactionType {
  CREDIT // Entrada de dinero (abono)
  DEBIT // Salida de dinero (cargo)
}

enum BankStatementStatus {
  OPEN // Estado de trabajo activo
  CLOSED // Conciliado / cerrado
}

model BankAccount {
  id             String    @id @default(cuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  accountId      String    @unique
  account        Account   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  name           String
  bankName       String
  accountNumber  String?
  currency       Currency  @default(VES)
  closingBalance Decimal   @default(0) @db.Decimal(19, 4)
  isActive       Boolean   @default(true)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  createdBy      String

  statements     BankStatement[]
  // ADR-030: pagos con GL auto-posting que usan esta cuenta bancaria
  paymentRecords PaymentRecord[] @relation("PaymentRecordBankAccount")
  paymentBatches PaymentBatch[]  @relation("PaymentBatchBankAccount")

  @@index([companyId])
}

model BankStatement {
  id             String              @id @default(cuid())
  bankAccountId  String
  bankAccount    BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  periodStart    DateTime            @db.Date
  periodEnd      DateTime            @db.Date
  openingBalance Decimal             @db.Decimal(19, 4)
  closingBalance Decimal             @db.Decimal(19, 4)
  status         BankStatementStatus @default(OPEN)
  importedAt     DateTime            @default(now())
  importedBy     String
  deletedAt      DateTime?

  transactions BankTransaction[]

  @@index([bankAccountId])
}

model BankTransaction {
  id                     String              @id @default(cuid())
  statementId            String
  statement              BankStatement       @relation(fields: [statementId], references: [id], onDelete: Restrict)
  // Desnormalizado desde BankStatement→BankAccount para soportar RLS policy (Fase 13D)
  companyId              String
  company                Company             @relation("BankTransactionCompany", fields: [companyId], references: [id], onDelete: Restrict)
  date                   DateTime            @db.Date
  description            String
  type                   BankTransactionType
  amount                 Decimal             @db.Decimal(19, 4)
  reference              String?
  isReconciled           Boolean             @default(false)
  // Match tipo 1: InvoicePayment — cancelación cartera CxC/CxP (Fase 17)
  matchedPaymentId       String?
  matchedPayment         InvoicePayment?     @relation(fields: [matchedPaymentId], references: [id], onDelete: Restrict)
  // Match tipo 2: Transaction — asiento de libro mayor (Fase 17B)
  matchedTransactionId   String?
  matchedTransaction     Transaction?        @relation("BankTransactionMatch", fields: [matchedTransactionId], references: [id], onDelete: Restrict)
  // Match tipo 3: PaymentRecord — pago multi-medio digital (Fase 17B)
  matchedPaymentRecordId String?
  matchedPaymentRecord   PaymentRecord?      @relation(fields: [matchedPaymentRecordId], references: [id], onDelete: Restrict)
  matchedAt              DateTime?
  matchedBy              String?
  deletedAt              DateTime?

  createdAt DateTime @default(now())

  // Fase 36C: Match tipo 4 — PaymentBatch (distribución A/P)
  matchedPaymentBatchId String?       @unique
  matchedPaymentBatch   PaymentBatch? @relation(fields: [matchedPaymentBatchId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([statementId])
  @@index([matchedPaymentId])
  @@index([matchedTransactionId])
  @@index([matchedPaymentRecordId])
}

// ─── Fase 13C Bloque 3: Snapshots de Saldos por Período ───────────────────────
// Saldo precalculado por cuenta al cierre de cada período contable.
// Permite que reportes (Balance General, Estado de Resultados) lean este snapshot
// en lugar de recalcular todos los asientos históricos en cada request.
// Nota: ExchangeRate (Fase 14) cubre las tasas históricas — no se necesita
// un modelo separado ExchangeRateSnapshot.
model PeriodSnapshot {
  id              String   @id @default(cuid())
  companyId       String
  periodId        String
  accountId       String
  balanceVes      Decimal  @db.Decimal(19, 4)
  balanceOriginal Decimal? @db.Decimal(19, 4)
  currency        Currency @default(VES)
  snapshotAt      DateTime @default(now())

  company Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  period  AccountingPeriod @relation(fields: [periodId], references: [id], onDelete: Restrict)
  account Account          @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([periodId, accountId])
  @@index([companyId, periodId])
}

// ─── Fase 21: Activos Fijos y Depreciación (VEN-NIF 16 / IAS 16) ─────────────

enum DepreciationMethod {
  LINEA_RECTA // (Costo − Valor Residual) / Vida Útil en meses
  SUMA_DIGITOS // Sum-of-years-digits
  UNIDADES_PRODUCCION // (Costo − Valor Residual) / Total Unidades × Unidades del período
}

enum FixedAssetStatus {
  ACTIVE
  DISPOSED // Dado de baja
  FULLY_DEPRECIATED
}

model FixedAsset {
  id                       String                      @id @default(cuid())
  companyId                String
  company                  Company                     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name                     String
  description              String?
  // Cuentas contables vinculadas
  assetAccountId           String // → Account tipo ASSET
  assetAccount             Account                     @relation("FixedAssetAccount", fields: [assetAccountId], references: [id], onDelete: Restrict)
  depreciationAccountId    String // → Account tipo EXPENSE (gasto depreciación)
  depreciationAccount      Account                     @relation("DepreciationExpenseAccount", fields: [depreciationAccountId], references: [id], onDelete: Restrict)
  accDepreciationAccountId String // → Account tipo ASSET crédito (depreciación acumulada)
  accDepreciationAccount   Account                     @relation("AccumulatedDepreciationAccount", fields: [accDepreciationAccountId], references: [id], onDelete: Restrict)
  // Datos del activo
  acquisitionDate          DateTime                    @db.Date
  acquisitionCost          Decimal                     @db.Decimal(19, 4)
  acquisitionCurrency      Currency                    @default(VES) // N2: moneda original de adquisicion
  bcvRateAtAcquisition     Decimal?                    @db.Decimal(19, 4) // N2: tasa BCV a la fecha de adquisicion
  residualValue            Decimal                     @default(0) @db.Decimal(19, 4)
  usefulLifeMonths         Int // vida útil en meses
  depreciationMethod       DepreciationMethod          @default(LINEA_RECTA)
  status                   FixedAssetStatus            @default(ACTIVE)
  // Solo para UNIDADES_PRODUCCION
  totalUnits               Int?
  unitsUsed                Int                         @default(0)
  // Localización y responsable (Ítem 40)
  location                 String?
  responsible              String?
  // Campos legales SENIAT — FC-02 (Art. 76 ISLR / Art. 91 Código de Comercio)
  invoiceNumber            String? // Nro. Factura de Compra — cruce Libro IVA Compras
  providerRif              String? // RIF del Proveedor — verificación retenciones
  serialNumber             String? // Nro. Serial / Placa del bien — identificación unívoca
  serviceStartDate         DateTime?                   @db.Date // Fecha de Puesta en Servicio (puede diferir de compra)
  internalCode             String? // Nro. Inventario Interno
  // Soft delete (tabla con relevancia contable — ADR-005)
  deletedAt                DateTime?
  createdAt                DateTime                    @default(now())
  createdBy                String
  updatedAt                DateTime                    @updatedAt
  entries                  DepreciationEntry[]
  inpcRestatements         FixedAssetINPCRestatement[]

  @@index([companyId])
  @@index([companyId, status])
}

// N3: Historial persistente de reajustes INPC por activo (Art. 173 ISLR)
model FixedAssetINPCRestatement {
  id                String     @id @default(cuid())
  companyId         String
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  assetId           String
  asset             FixedAsset @relation(fields: [assetId], references: [id], onDelete: Restrict)
  inpcPeriodYear    Int
  inpcPeriodMonth   Int
  factor            Decimal    @db.Decimal(19, 10)
  adjustmentAmount  Decimal    @db.Decimal(19, 4)
  previousBookValue Decimal    @db.Decimal(19, 4)
  newRestatedValue  Decimal    @db.Decimal(19, 4)
  equityAccountId   String
  transactionId     String     @unique
  userId            String
  createdAt         DateTime   @default(now())

  @@unique([assetId, inpcPeriodYear, inpcPeriodMonth])
  @@index([companyId])
  @@index([assetId])
}

model DepreciationEntry {
  id                      String       @id @default(cuid())
  companyId               String
  fixedAssetId            String
  fixedAsset              FixedAsset   @relation(fields: [fixedAssetId], references: [id], onDelete: Restrict)
  periodYear              Int
  periodMonth             Int // 1–12
  amount                  Decimal      @db.Decimal(19, 4)
  accumulatedDepreciation Decimal      @db.Decimal(19, 4)
  bookValue               Decimal      @db.Decimal(19, 4) // costo − depreciación acumulada
  transactionId           String?      @unique // → Transaction generada
  transaction             Transaction? @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  postedAt                DateTime?
  createdAt               DateTime     @default(now())

  @@unique([fixedAssetId, periodYear, periodMonth])
  @@index([companyId, periodYear, periodMonth])
}

// ─── Fase 22: Ajuste por Inflación Fiscal (INPC / VEN-NIF 3) ─────────────────

model INPCRate {
  id         String   @id @default(cuid())
  companyId  String
  year       Int
  month      Int // 1-12
  indexValue Decimal  @db.Decimal(18, 6) // índice INPC publicado por BCV
  source     String?  @default("BCV")
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, year, month])
  @@index([companyId])
}

model InflationAdjustment {
  id               String   @id @default(cuid())
  companyId        String
  periodYear       Int
  periodMonth      Int // período que se está ajustando
  baseYear         Int // año del índice base usado
  baseMonth        Int // mes del índice base usado
  accountId        String
  originalAmount   Decimal  @db.Decimal(19, 4) // saldo de la cuenta antes del ajuste (ADR-002)
  adjustmentAmount Decimal  @db.Decimal(19, 4) // monto del ajuste = original × (factor − 1) (ADR-002)
  cumulativeIndex  Decimal  @db.Decimal(18, 6) // factor = currentIndex / baseIndex
  transactionId    String // NON-NULLABLE — VEN-NIF 3: todo ajuste DEBE tener asiento
  createdAt        DateTime @default(now())

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Restrict)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@unique([companyId, periodYear, periodMonth, accountId])
  @@index([companyId, periodYear, periodMonth])
}

// ─── Fase 28D: Módulo Inventario ─────────────────────────────────────────────

// Tipo de producto — NIIF para PYMES Sección 13 (Inventarios aplica solo a activos tangibles)
enum ItemType {
  GOODS // Mercancía para reventa (default) — movimientos físicos permitidos
  SERVICE // Servicio intangible — NO tiene stock físico; ENTRADA/SALIDA bloqueadas
  RAW_MATERIAL // Materia prima — movimientos físicos permitidos
  FINISHED_GOOD // Producto terminado — movimientos físicos permitidos
}

enum MovementType {
  ENTRADA // compra, recepción de producción, ajuste positivo
  SALIDA // venta, consumo, ajuste negativo
  AJUSTE // corrección administrativa — requiere motivo
}

enum MovementStatus {
  DRAFT // registrado sin asiento — solo ADMINISTRATIVE puede ver
  POSTED // asiento generado y contabilizado — ACCOUNTANT aprobó
  VOIDED // anulado con contrapartida — NUNCA DELETE
}

// Nivel de control de stock al facturar — configurado por empresa en CompanySettings
// ADR-024 D-2.1
enum StockControlLevel {
  WARN // permite facturar con stock negativo — muestra advertencia en UI
  CONFIRM // requiere confirmación explícita si stock < cantidad solicitada
  BLOCK // bloquea emisión si stock < cantidad en alguna línea
}

model InventoryItem {
  id             String              @id @default(cuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sku            String
  name           String
  description    String?
  // Denorm de la unidad base — sincronizado por InventoryUomService al crear/actualizar unidad base
  baseUnitName   String // sincronizado con InventoryItemUnit.name donde isBase = true
  baseUnitAbbr   String // sincronizado con InventoryItemUnit.abbreviation
  baseUnitId     String?
  baseUnit       InventoryItemUnit?  @relation("ItemBaseUnit", fields: [baseUnitId], references: [id], onDelete: Restrict)
  averageCost    Decimal             @default(0) @db.Decimal(19, 4) // CPP vigente — siempre en unidad base
  stockQuantity  Decimal             @default(0) @db.Decimal(19, 4) // existencia en unidad base
  minimumStock   Decimal?            @db.Decimal(19, 4) // umbral para alerta de bajo stock
  itemType       ItemType            @default(GOODS) // NIIF Sec.13 — SERVICE bloquea movimientos físicos
  accountId      String?
  account        Account?            @relation("InventoryItemAccount", fields: [accountId], references: [id], onDelete: Restrict)
  cogsAccountId  String?
  cogsAccount    Account?            @relation("CogsAccount", fields: [cogsAccountId], references: [id], onDelete: Restrict)
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdBy      String
  // Fase 35G: Lot/Serial Tracking — ADR-021 D-1
  trackingType   TrackingType        @default(NONE)
  movements      InventoryMovement[]
  units          InventoryItemUnit[] @relation("ItemUnits")
  lots           InventoryLot[]
  serials        InventorySerial[]
  // Fase 37A: líneas de factura que referenciaron este ítem
  invoiceLines   InvoiceLine[]
  // OM-08: líneas de cotización y orden vinculadas al catálogo
  quotationItems QuotationItem[]
  orderItems     OrderItem[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([companyId, deletedAt])
}

model InventoryMovement {
  id                   String                    @id @default(cuid())
  companyId            String
  company              Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  itemId               String
  item                 InventoryItem             @relation(fields: [itemId], references: [id], onDelete: Restrict)
  type                 MovementType
  status               MovementStatus            @default(DRAFT)
  quantity             Decimal                   @db.Decimal(19, 4) // cantidad en UNIDAD BASE — siempre positivo
  unitCost             Decimal                   @db.Decimal(19, 4) // costo por UNIDAD BASE (snapshot CPP)
  totalCost            Decimal                   @db.Decimal(19, 4) // quantity × unitCost — almacenado
  // Fase 35F: Unidades de Medida — ADR-018
  unitId               String?
  unit                 InventoryItemUnit?        @relation(fields: [unitId], references: [id], onDelete: Restrict)
  quantityInUnit       Decimal                   @db.Decimal(19, 4) // cantidad en la unidad del movimiento
  conversionSnapshot   Decimal                   @db.Decimal(19, 10) // factor inmutable al momento del movimiento — ADR-018 D-3
  invoiceId            String?
  invoice              Invoice?                  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  transactionId        String?                   @unique
  transaction          Transaction?              @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  // R-04 auditoría SENIAT: cuenta contrapartida para completar el asiento (partida doble)
  // ENTRADA: CR = Proveedores/Caja/Banco. AJUSTE: CR = Merma/Pérdida o DR = Sobrante
  counterpartAccountId String?
  counterpartAccount   Account?                  @relation("InventoryMovementCounterpart", fields: [counterpartAccountId], references: [id], onDelete: Restrict)
  // R-02 auditoría SENIAT: tasa BCV histórica a la fecha del movimiento (Bs./$)
  exchangeRateVes      Decimal?                  @db.Decimal(10, 4)
  reference            String?
  notes                String?
  date                 DateTime
  idempotencyKey       String                    @unique
  createdAt            DateTime                  @default(now())
  createdBy            String
  postedAt             DateTime?
  postedBy             String?
  // Fase 35G: Lot/Serial Tracking — ADR-021 D-4
  lotLines             InventoryMovementLot[]
  serialLines          InventoryMovementSerial[]
  // Fase 37A: línea de factura que originó este movimiento
  invoiceLine          InvoiceLine?

  @@index([companyId])
  @@index([companyId, itemId])
  @@index([companyId, status])
  @@index([companyId, date])
  @@index([invoiceId])
}

// ─── Fase 35F: Unidades de Medida Múltiples (UoM) — ADR-018 ─────────────────
// Una unidad base por ítem (isBase = true). Stock y CPP SIEMPRE en unidad base.
// Conversión ocurre en InventoryOperationsService.resolveQuantity() antes de
// modificar stockQuantity/averageCost — InventoryAccountingService no requiere cambios.

model InventoryItemUnit {
  id               String        @id @default(cuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  itemId           String
  item             InventoryItem @relation("ItemUnits", fields: [itemId], references: [id], onDelete: Restrict)
  name             String
  abbreviation     String
  // Factor: cuántas unidades BASE equivale 1 de ESTA unidad.
  // Unidad base: conversionFactor = 1.0000000000. NUNCA Float — R-5 / ADR-002.
  // Ejemplo: 1 Caja = 12 Unidades → conversionFactor = 12.0000000000
  conversionFactor Decimal       @db.Decimal(19, 10)
  isBase           Boolean       @default(false)
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  createdBy        String

  movements    InventoryMovement[]
  itemsAsBase  InventoryItem[]     @relation("ItemBaseUnit")
  // Fase 37A: líneas de factura que usan esta unidad de venta
  invoiceLines InvoiceLine[]

  // @@unique([itemId, isBase]) ELIMINADO — crearía constraint incorrecto sobre isBase=false.
  // Constraint de una sola unidad base por ítem gestionado vía partial index SQL:
  //   CREATE UNIQUE INDEX "uq_inventory_item_unit_base" ON "InventoryItemUnit"("itemId") WHERE "isBase" = true
  // Ver migración: 20260430100000_fase35f_uom_a — ADR-018 D-4 / security-agent CRITICAL-1
  @@unique([itemId, name])
  @@index([companyId])
  @@index([itemId])
}

// ─── Fase 35G: Lot/Serial Tracking — ADR-021 ─────────────────────────────────

enum TrackingType {
  NONE // sin tracking — comportamiento pre-35G
  LOT // seguimiento por lote (número de lote + fecha de vencimiento)
  SERIAL // seguimiento por número de serie (1 serial = 1 unidad física)
}

enum SerialStatus {
  AVAILABLE // en stock, disponible para venta/uso
  IN_TRANSIT // reservado por un movimiento DRAFT (no POSTED aún)
  SOLD // salida POSTED — ya no está en inventario físico
  VOIDED // el movimiento de creación fue VOIDED — registro histórico inmutable
}

// Representa un lote recibido de un ítem con trackingType = LOT.
// quantityOnHand: saldo actual en unidad base — actualizado dentro del $transaction
// Serializable de postMovement (ADR-021 D-5).
// Un lote no se elimina aunque su saldo llegue a cero — es registro histórico.
model InventoryLot {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  itemId         String
  item           InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lotNumber      String // número de lote del proveedor — scoped por ítem
  expiresAt      DateTime? // null = sin fecha de vencimiento
  quantityOnHand Decimal       @db.Decimal(19, 4) // en unidad base — nunca negativo (CHECK en DB)
  notes          String?
  receivedAt     DateTime      @default(now()) // fecha de recepción física
  createdAt      DateTime      @default(now())
  createdBy      String // Clerk userId

  movementLines InventoryMovementLot[]

  // companyId en el unique: simétrico con InventorySerial — P2002 no debe revelar lotes de otra empresa (ADR-021 CRITICAL-2)
  @@unique([companyId, itemId, lotNumber])
  @@index([companyId])
  @@index([companyId, itemId])
  @@index([companyId, itemId, expiresAt]) // queries FEFO: ORDER BY expiresAt ASC NULLS LAST
}

// Tabla intermedia: un movimiento puede consumir/producir stock de múltiples lotes.
// Invariante: SUM(quantity) por movementId == InventoryMovement.quantity para movimientos POSTED.
model InventoryMovementLot {
  id         String            @id @default(cuid())
  movementId String
  movement   InventoryMovement @relation(fields: [movementId], references: [id], onDelete: Restrict)
  lotId      String
  lot        InventoryLot      @relation(fields: [lotId], references: [id], onDelete: Restrict)
  quantity   Decimal           @db.Decimal(19, 4) // en unidad base — siempre positivo

  @@unique([movementId, lotId])
  @@index([movementId])
  @@index([lotId])
}

// Representa una unidad física identificada por número de serie.
// trackingType = SERIAL: 1 movimiento ENTRADA quantity=N → N registros InventorySerial.
// NUNCA eliminar un serial — VOIDED es el estado terminal para anulaciones.
model InventorySerial {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  itemId       String
  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  serialNumber String // número de serie — scoped por companyId+itemId (ADR-021 D-3)
  status       SerialStatus  @default(AVAILABLE)
  notes        String?
  createdAt    DateTime      @default(now())
  createdBy    String // Clerk userId
  soldAt       DateTime? // poblado cuando status → SOLD (postMovement SALIDA)
  voidedAt     DateTime? // poblado cuando status → VOIDED (voidMovement)

  movementLines InventoryMovementSerial[]

  // companyId explícito: dos empresas distintas pueden tener el mismo serialNumber sin conflicto
  // (sensibilidad fiscal Venezuela: series ligadas a importaciones/SENIAT — ADR-021 D-3)
  @@unique([companyId, itemId, serialNumber])
  @@index([companyId])
  @@index([companyId, itemId])
  @@index([companyId, itemId, status]) // queries de disponibilidad en formulario SALIDA
}

// Tabla intermedia: un movimiento referencia exactamente los seriales operados.
// ENTRADA: crea los seriales + esta línea en el mismo $transaction.
// SALIDA: el input provee los serialIds; se valida status = AVAILABLE antes de postear.
model InventoryMovementSerial {
  id         String            @id @default(cuid())
  movementId String
  movement   InventoryMovement @relation(fields: [movementId], references: [id], onDelete: Restrict)
  serialId   String
  serial     InventorySerial   @relation(fields: [serialId], references: [id], onDelete: Restrict)

  @@unique([movementId, serialId])
  @@index([movementId])
  @@index([serialId])
}

// ─── Fase 36C: PaymentBatch — Distribución de Pagos A/P (ADR-022) ────────────

enum PaymentBatchStatus {
  DRAFT
  APPLIED
  VOID
}

model PaymentBatch {
  id                  String             @id @default(cuid())
  companyId           String
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  status              PaymentBatchStatus @default(DRAFT)
  method              PaymentMethod
  totalAmountVes      Decimal            @db.Decimal(19, 4)
  currency            String             @default("VES")
  totalAmountOriginal Decimal?           @db.Decimal(19, 4)
  exchangeRateId      String?
  exchangeRate        ExchangeRate?      @relation(fields: [exchangeRateId], references: [id], onDelete: Restrict)
  referenceNumber     String?
  originBank          String?
  destBank            String?
  commissionPct       Decimal?           @db.Decimal(5, 2)
  commissionAmount    Decimal?           @db.Decimal(19, 4)
  totalIgtfAmount     Decimal?           @db.Decimal(19, 4)
  date                DateTime           @db.Date
  notes               String?
  voidReason          String?
  voidedAt            DateTime?
  voidedBy            String?
  bankTransaction     BankTransaction?
  deletedAt           DateTime?
  createdAt           DateTime           @default(now())
  createdBy           String
  idempotencyKey      String             @unique
  // ADR-030: FK a cuenta bancaria para GL auto-posting en applyBatch()
  bankAccountId       String?
  bankAccount         BankAccount?       @relation("PaymentBatchBankAccount", fields: [bankAccountId], references: [id], onDelete: Restrict)
  // ADR-030: FK al Transaction generado por GL auto-posting (un batch = un asiento)
  glTransactionId     String?            @unique
  glTransaction       Transaction?       @relation("PaymentBatchGLTransaction", fields: [glTransactionId], references: [id], onDelete: Restrict)

  lines PaymentBatchLine[]

  @@index([companyId])
  @@index([companyId, date])
  @@index([companyId, status])
  @@index([companyId, bankAccountId])
}

model PaymentBatchLine {
  id             String       @id @default(cuid())
  paymentBatchId String
  paymentBatch   PaymentBatch @relation(fields: [paymentBatchId], references: [id], onDelete: Restrict)
  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amountVes      Decimal      @db.Decimal(19, 4)
  amountOriginal Decimal?     @db.Decimal(19, 4)
  igtfAmount     Decimal?     @db.Decimal(19, 4)
  notes          String?
  createdAt      DateTime     @default(now())

  @@unique([paymentBatchId, invoiceId])
  @@index([paymentBatchId])
  @@index([invoiceId])
}

// ─── Fase 30: Exportación Masiva / Backup ────────────────────────────────────

enum ExportJobStatus {
  PENDING
  PROCESSING
  DONE
  ERROR
}

model ExportJob {
  id        String          @id @default(cuid())
  companyId String
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy String // Clerk userId
  status    ExportJobStatus @default(PENDING)
  dateFrom  DateTime        @db.Date
  dateTo    DateTime        @db.Date
  fileData  Bytes? // ZIP contents — null until DONE
  fileSize  Int? // bytes, for UI display
  expiresAt DateTime? // set to now()+24h on DONE
  errorMsg  String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([companyId])
  @@index([createdBy])
}

// ─── Fase 28: Módulo Compras y Ventas ────────────────────────────────────────

enum QuotationType {
  PURCHASE // Cotización de compra (enviada a proveedor)
  SALE // Presupuesto/Cotización de venta (enviada a cliente)
}

enum QuotationStatus {
  DRAFT // Borrador — editable
  PENDING_APPROVAL // Enviado a aprobación — solo lectura para ADMINISTRATIVE
  APPROVED // Aprobado — listo para convertir a Orden
  REJECTED // Rechazado — terminal
  CANCELLED // Cancelado — terminal
  CONVERTED // Convertido a Orden — terminal
}

enum OrderStatus {
  DRAFT // Borrador — editable
  APPROVED // Aprobado — listo para convertir a Factura
  CONVERTED // Convertido a Factura — terminal
  CANCELLED // Cancelado — terminal
}

enum OrderDocType {
  PURCHASE_QUOTATION // COT-XXXX
  SALE_QUOTATION // PRE-XXXX
  PURCHASE_ORDER // OC-XXXX
  SALE_ORDER // OV-XXXX
}

model OrderNumberSequence {
  id         String       @id @default(cuid())
  companyId  String
  docType    OrderDocType
  lastNumber Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, docType])
  @@index([companyId])
}

model Quotation {
  id              String          @id @default(cuid())
  companyId       String
  type            QuotationType
  status          QuotationStatus @default(DRAFT)
  number          String
  counterpartName String
  counterpartRif  String?
  validUntil      DateTime        @db.Date
  notes           String?
  subtotal        Decimal         @db.Decimal(19, 4)
  taxAmount       Decimal         @db.Decimal(19, 4)
  total           Decimal         @db.Decimal(19, 4)
  currency        Currency        @default(VES)
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  company Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  items   QuotationItem[]
  order   Order?

  @@unique([companyId, number, type])
  @@index([companyId, type, status])
  @@index([companyId, createdAt(sort: Desc)])
}

model QuotationItem {
  id              String  @id @default(cuid())
  quotationId     String
  inventoryItemId String? // OM-08: FK opcional al catálogo de productos
  description     String
  unit            String
  quantity        Decimal @db.Decimal(19, 4)
  unitPrice       Decimal @db.Decimal(19, 4)
  taxRate         Decimal @default(0) @db.Decimal(5, 2)
  totalPrice      Decimal @db.Decimal(19, 4)

  quotation     Quotation      @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([quotationId])
  @@index([inventoryItemId])
}

model Order {
  id              String        @id @default(cuid())
  companyId       String
  type            QuotationType
  status          OrderStatus   @default(DRAFT)
  number          String
  quotationId     String?       @unique
  counterpartName String
  counterpartRif  String?
  expectedDate    DateTime?     @db.Date
  notes           String?
  subtotal        Decimal       @db.Decimal(19, 4)
  taxAmount       Decimal       @db.Decimal(19, 4)
  total           Decimal       @db.Decimal(19, 4)
  currency        Currency      @default(VES)
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  company   Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  quotation Quotation?  @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  items     OrderItem[]
  invoice   Invoice?

  @@unique([companyId, number, type])
  @@index([companyId, type, status])
  @@index([companyId, createdAt(sort: Desc)])
}

// ─── Fase NOM-A: Configuración de Nómina ────────────────────────────────────

enum WorkSchedule {
  LUNES_VIERNES // Lun-Vie (Sab+Dom libres) — jornada estándar LOTTT
  LUNES_SABADO // Lun-Sab (solo Dom libre)
  LUNES_SABADO_MEDIO // Lun-Vie + Sab medio turno
}

enum PayrollSizeRange {
  SMALL // < 20 empleados
  MEDIUM // 20-100 empleados
  LARGE // > 100 empleados
}

enum LottRegime {
  POST_2012 // Solo régimen post-Ley LOTTT 2012
  MIXED // Empleados de ambos regímenes (pre-1997 LOT + post-2012)
}

// Tipo de jornada laboral (LOTTT Arts. 173-177) — distinto de WorkSchedule (días semana)
enum JornadaType {
  DIURNA
  NOCTURNA
  MIXTA
}

enum PayrollPaymentCurrency {
  VES
  USD
  MIXED
}

enum PayrollFrequency {
  BIWEEKLY // Quincenal
  MONTHLY // Mensual
}

enum CestaTicketType {
  CARD // Tarjeta de alimentación
  CASH // Efectivo
  NONE // No aplica
}

enum FideicomisoType {
  EXTERNAL_BANK // Fideicomiso en banco externo
  INTERNAL // Registro contable interno
}

enum LegalThresholdType {
  SALARY_MIN_VES // Salario mínimo mensual nacional (Bs.) — Decreto presidencial
  UT_VALUE // Unidad Tributaria (Bs.) — Providencia SENIAT
}

// ─── LegalThreshold ───────────────────────────────────────────────────────────
// Histórico de topes legales venezolanos por empresa.
// Cada vez que un decreto modifica el salario mínimo o la UT, el administrador
// agrega una nueva fila con effectiveFrom = fecha de vigencia.
// PayrollRunService consulta el tope vigente a la fecha del período calculado.

model LegalThreshold {
  id            String             @id @default(cuid())
  companyId     String
  type          LegalThresholdType
  effectiveFrom DateTime           @db.Date
  value         Decimal            @db.Decimal(18, 2)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, type, effectiveFrom])
  @@index([companyId, type, effectiveFrom])
}

model PayrollConfig {
  id                            String                 @id @default(cuid())
  companyId                     String                 @unique // una config por empresa
  // Empresa
  sizeRange                     PayrollSizeRange
  lottRegime                    LottRegime
  // Organismos activos
  ivssEnabled                   Boolean                @default(true)
  incesEnabled                  Boolean                @default(true)
  banavihEnabled                Boolean                @default(true)
  rpeEnabled                    Boolean                @default(true) // Paro Forzoso RPE 0.5% (LSSO Art. 7)
  cestaTicketType               CestaTicketType
  // Pagos
  paymentCurrency               PayrollPaymentCurrency
  frequency                     PayrollFrequency
  fideicomiso                   FideicomisoType
  // Fase NOM-C: Cuentas contables para asiento de causación (nullable hasta configurar)
  // ADR-013 Decisión 3: configurables por empresa (no hardcoded)
  expenseAccountId              String? // EXPENSE — Gastos de Personal / Sueldos y Salarios
  payableAccountId              String? // LIABILITY — Sueldos y Salarios por Pagar (neto empleados)
  ivssPayableAccountId          String? // LIABILITY — IVSS Obrero por Pagar
  faovPayableAccountId          String? // LIABILITY — FAOV / BANAVIH por Pagar
  incesPayableAccountId         String? // LIABILITY — INCES por Pagar
  rpePayableAccountId           String? // LIABILITY — Paro Forzoso RPE por Pagar
  // Fase NOM-D: Cuentas contables para prestaciones sociales, vacaciones y utilidades
  // ADR-014 Decisión 7: causación periódica requiere cuentas separadas
  benefitsExpenseAccountId      String? // EXPENSE — Gastos Prestaciones Sociales
  benefitsPayableAccountId      String? // LIABILITY — Prestaciones Sociales por Pagar
  vacationPayableAccountId      String? // LIABILITY — Vacaciones por Pagar
  profitSharingPayableAccountId String? // LIABILITY — Utilidades por Pagar
  // F-02/F-03: Aportes patronales — cuentas GL para causación de contribuciones del patrono
  ivssPatronalAccountId         String? // LIABILITY — IVSS Patronal por Pagar (LSS Art. 62: 9%)
  incesPatronalAccountId        String? // LIABILITY — INCES Patronal por Pagar (Ley INCES Art. 30: 2%)
  faovPatronalAccountId         String? // LIABILITY — FAOV Patronal por Pagar (LAH Art. 172: 2%)
  rpePatronalAccountId          String? // LIABILITY — Paro Forzoso Patronal por Pagar (LSSO Art. 7: 2%)
  // Préstamos a empleados — cuentas GL para desembolso y recuperación en nómina
  loanReceivableAccountId       String? // ASSET — Préstamos a Empleados (crédito cuando cuota se descuenta en nómina)
  disbursementBankAccountId     String? // ASSET — Banco desde donde se desembolsa el préstamo al empleado
  // Fase NOM-D: Configuración de beneficios legales
  profitDays                    Int                    @default(15) // días de utilidades (15–120 LOTTT Art. 131)
  vacationBonusDays             Int                    @default(7) // días bono vacacional año 1 (LOTTT Art. 223)
  // VAC-1: jornada laboral para cómputo de días hábiles en vacaciones (LOTTT)
  workSchedule                  WorkSchedule           @default(LUNES_VIERNES)
  // Fase NOM-E: Valor de la Unidad Tributaria para cálculo de techo IVSS (LSS Art. 62)
  // El contador lo actualiza anualmente cuando el SENIAT publica el nuevo valor.
  // NULL = no configurado → reportes IVSS omiten el techo y lo informan al usuario.
  utValue                       Decimal?               @db.Decimal(10, 2)
  // Tope de cotización: salario mínimo nacional vigente (Bs/mes).
  // Cuando > 0: IVSS cap = 5 × salaryMinimumVes; FAOV cap = 10 × salaryMinimumVes.
  // Cuando NULL/0: sin tope (uso previo al decreto — mantiene retro-compatibilidad).
  salaryMinimumVes              Decimal?               @db.Decimal(18, 2)
  // Timestamps
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt

  company                     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  expenseAccount              Account? @relation("PayrollExpenseAccount", fields: [expenseAccountId], references: [id], onDelete: Restrict)
  payableAccount              Account? @relation("PayrollPayableAccount", fields: [payableAccountId], references: [id], onDelete: Restrict)
  ivssPayableAccount          Account? @relation("PayrollIvssPayable", fields: [ivssPayableAccountId], references: [id], onDelete: Restrict)
  faovPayableAccount          Account? @relation("PayrollFaovPayable", fields: [faovPayableAccountId], references: [id], onDelete: Restrict)
  incesPayableAccount         Account? @relation("PayrollIncesPayable", fields: [incesPayableAccountId], references: [id], onDelete: Restrict)
  rpePayableAccount           Account? @relation("PayrollRpePayable", fields: [rpePayableAccountId], references: [id], onDelete: Restrict)
  benefitsExpenseAccount      Account? @relation("PayrollBenefitsExpense", fields: [benefitsExpenseAccountId], references: [id], onDelete: Restrict)
  benefitsPayableAccount      Account? @relation("PayrollBenefitsPayable", fields: [benefitsPayableAccountId], references: [id], onDelete: Restrict)
  vacationPayableAccount      Account? @relation("PayrollVacationPayable", fields: [vacationPayableAccountId], references: [id], onDelete: Restrict)
  profitSharingPayableAccount Account? @relation("PayrollProfitPayable", fields: [profitSharingPayableAccountId], references: [id], onDelete: Restrict)
  loanReceivableAccount       Account? @relation("PayrollLoanReceivable", fields: [loanReceivableAccountId], references: [id], onDelete: Restrict)
  disbursementBankAccount     Account? @relation("PayrollDisbursementBank", fields: [disbursementBankAccountId], references: [id], onDelete: Restrict)
  ivssPatronalAccount         Account? @relation("PayrollIvssPatronal", fields: [ivssPatronalAccountId], references: [id], onDelete: Restrict)
  incesPatronalAccount        Account? @relation("PayrollIncesPatronal", fields: [incesPatronalAccountId], references: [id], onDelete: Restrict)
  faovPatronalAccount         Account? @relation("PayrollFaovPatronal", fields: [faovPatronalAccountId], references: [id], onDelete: Restrict)
  rpePatronalAccount          Account? @relation("PayrollRpePatronal", fields: [rpePatronalAccountId], references: [id], onDelete: Restrict)
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  inventoryItemId String? // OM-08: FK opcional al catálogo de productos
  description     String
  unit            String
  quantity        Decimal @db.Decimal(19, 4)
  unitPrice       Decimal @db.Decimal(19, 4)
  taxRate         Decimal @default(0) @db.Decimal(5, 2)
  totalPrice      Decimal @db.Decimal(19, 4)

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([inventoryItemId])
}

// ─── Fase NOM-B: Empleados, Conceptos, Feriados y Tipos de Ausencia ──────────

enum ContractType {
  INDEFINIDO // Tiempo indeterminado (LOTTT Art. 61)
  DETERMINADO // Tiempo determinado (LOTTT Art. 64)
  OBRA_DETERMINADA // Por obra determinada (LOTTT Art. 62)
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum LoanStatus {
  ACTIVE
  PAID
  CANCELLED
}

enum ConceptType {
  EARNING // Ingreso / asignación
  DEDUCTION // Deducción / descuento del trabajador
  EMPLOYER_COST // Aporte patronal — no afecta neto del empleado (IVSS/INCES/FAOV/RPE patronal)
}

enum AbsenceCategory {
  JUSTIFIED // Justificada (pagada)
  UNJUSTIFIED // Injustificada (puede descontar)
  MEDICAL // Reposo médico (IVSS cubre parcialmente)
  PERMISSION // Permiso especial (LOTTT Art. 420)
}

enum MaritalStatus {
  SOLTERO
  CASADO
  DIVORCIADO
  VIUDO
  UNION_ESTABLE // Unión estable de hecho (LOPNNA / Código Civil)
}

enum PayrollWorkerType {
  OBRERO // LOTTT Art. 1: trabajo manual o semi-manual
  EMPLEADO // LOTTT Art. 1: servicios, técnico u oficina
}

// ─── Employee ─────────────────────────────────────────────────────────────────
// Campos LOTTT obligatorios: nombre, cédula, fecha ingreso, cargo, contrato, régimen
// cedulaType + cedulaNumber forman clave única por empresa (@@unique)
// onDelete: Restrict — nunca eliminar empleados con historial contable

model Employee {
  id                String            @id @default(cuid())
  companyId         String
  // Identificación
  firstName         String
  lastName          String
  cedulaType        String // "V" | "E"
  cedulaNumber      String // solo dígitos
  // Contrato LOTTT
  contractType      ContractType
  employeeRegime    LottRegime // por empleado — empresa MIXED puede tener ambos
  hireDate          DateTime          @db.Date
  terminationDate   DateTime?         @db.Date
  status            EmployeeStatus    @default(ACTIVE)
  // Cargo
  position          String
  department        String?
  costCenter        String? // centro de costo (Ítem 52)
  // Contacto
  email             String?
  phone             String?
  // Datos bancarios (para nómina)
  bankName          String?
  bankAccount       String?
  // Parafiscal (F-01 — IVSS/Banavih/ISLR D.1808)
  ivssNumber        String? // Número afiliación IVSS (Forma 14-02)
  banavihNumber     String? // Número afiliación Banavih/FAOV (FAOVWeb)
  dependents        Int? // Cargas familiares para ISLR (D. 1808)
  birthDate         DateTime?         @db.Date
  workSchedule      JornadaType? // Jornada laboral LOTTT Arts. 173-177
  // Clasificación LOTTT y estado civil (auditoria 2026-06-02)
  maritalStatus     MaritalStatus? // Estado civil — ISLR D. 1808
  payrollWorkerType PayrollWorkerType @default(EMPLEADO) // Tipo trabajador LOTTT Art. 1
  contractEndDate   DateTime?         @db.Date // Vencimiento contrato DETERMINADO (LOTTT Art. 64)
  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  company              Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  salaryHistory        SalaryHistory[]
  // Fase NOM-C
  payrollRunLines      PayrollRunLine[]
  // Fase NOM-D
  benefitBalance       BenefitBalance?
  benefitAdvances      BenefitAdvance[]
  vacationRecords      VacationRecord[]
  profitSharingRecords ProfitSharingRecord[]
  terminations         Termination[]
  loans                EmployeeLoan[]

  @@unique([companyId, cedulaType, cedulaNumber])
  @@index([companyId, status])
  @@index([companyId, lastName, firstName])
}

// ─── SalaryHistory ────────────────────────────────────────────────────────────
// Append-only: cada cambio de salario agrega una fila nueva (no se elimina ni edita).
// El salario vigente es el registro con mayor effectiveFrom <= hoy.
// NOM-B-03: cada INSERT en SalaryHistory va acompañado de un AuditLog.

model SalaryHistory {
  id              String                 @id @default(cuid())
  companyId       String
  employeeId      String
  effectiveFrom   DateTime               @db.Date
  amount          Decimal                @db.Decimal(19, 4)
  currency        PayrollPaymentCurrency
  createdByUserId String
  createdAt       DateTime               @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([employeeId, effectiveFrom(sort: Desc)])
  @@index([companyId])
}

// ─── PayrollConcept ───────────────────────────────────────────────────────────
// Catálogo de conceptos de nómina configurables por empresa.
// isSystem = true → conceptos generados automáticamente (IVSS, INCES, Banavih);
// no se pueden eliminar, solo desactivar.

model PayrollConcept {
  id                    String      @id @default(cuid())
  companyId             String
  code                  String // corto, ej: "SAL_BASE", "IVSS_OBR"
  name                  String
  type                  ConceptType
  isSystem              Boolean     @default(false)
  isActive              Boolean     @default(true)
  // LOTTT: indica si este concepto impacta el salario integral (base de prestaciones/vacaciones).
  // false → CESTA_TICKET, bonos no salariales. true → SAL_BASE, HE_DIURNA, HE_NOCTURNA, etc.
  affectsSalaryIntegral Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  // Fase NOM-C
  payrollRunLines PayrollRunLine[]

  @@unique([companyId, code])
  @@index([companyId, type, isActive])
}

// ─── PublicHoliday ────────────────────────────────────────────────────────────
// Feriados nacionales (Art. 184–190 LOTTT).
// isRecurring = true → se repite cada año en la misma fecha (mes/día).

model PublicHoliday {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  date        DateTime @db.Date
  isRecurring Boolean  @default(true)
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, date])
}

// ─── AbsenceType ─────────────────────────────────────────────────────────────
// Tipos de ausencia configurables. isSystem = true → no eliminables.

model AbsenceType {
  id        String          @id @default(cuid())
  companyId String
  name      String
  category  AbsenceCategory
  isPaid    Boolean         @default(true)
  isSystem  Boolean         @default(false)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, isActive])
}

// ─── Fase NOM-C: Motor de Cálculo de Nómina ──────────────────────────────────

enum PayrollRunStatus {
  DRAFT // Calculado — editable, no contabilizado
  APPROVED // Aprobado — asiento contable generado, inmutable
  CANCELLED // Anulado — estado terminal, solo desde DRAFT
}

// ─── PayrollRun ───────────────────────────────────────────────────────────────
// Cabecera de un proceso de nómina para un período específico.
// @@unique([companyId, periodStart, periodEnd]) previene doble-proceso a nivel DB.
// onDelete: Restrict — nunca eliminar runs con líneas contabilizadas (ADR-003).
// totales calculados server-side — NUNCA del cliente (ADR-006 D-2).

model PayrollRun {
  id                 String           @id @default(cuid())
  companyId          String
  periodStart        DateTime         @db.Date
  periodEnd          DateTime         @db.Date
  status             PayrollRunStatus @default(DRAFT)
  // Totales calculados server-side al momento del cálculo (inmutables post-APPROVED)
  totalEarnings      Decimal          @db.Decimal(18, 2)
  totalDeductions    Decimal          @db.Decimal(18, 2)
  totalNet           Decimal          @db.Decimal(18, 2)
  totalEmployerCosts Decimal          @default(0) @db.Decimal(18, 2) // F-03: aportes patronales
  employeeCount      Int
  // C-05: tasa BCV activa del período — snapshot para auditoría histórica
  bcvRateAtRun       Decimal?         @db.Decimal(16, 4)
  // Vínculo al asiento contable (nullable hasta APPROVED — ADR-013 Decisión 4)
  transactionId      String?          @unique
  // Auditoría
  createdByUserId    String
  approvedByUserId   String?
  cancelledByUserId  String?
  approvedAt         DateTime?
  cancelledAt        DateTime?
  // Previene doble submit desde UI (idempotencyKey único por request)
  idempotencyKey     String           @unique
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  transaction Transaction?     @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  lines       PayrollRunLine[]

  // GUARD doble-proceso: un solo run activo por empresa y período (ADR-013 Decisión 1)
  @@unique([companyId, periodStart, periodEnd])
  @@index([companyId, status])
  @@index([companyId, periodStart])
}

// ─── PayrollRunLine ───────────────────────────────────────────────────────────
// Una línea = un concepto para un empleado en un run.
// Almacena snapshot de salario + FK de auditoría (ADR-013 Decisión 2).
// onDelete: Restrict — nunca eliminar líneas contabilizadas (ADR-003).

model PayrollRunLine {
  id                     String                  @id @default(cuid())
  companyId              String
  payrollRunId           String
  employeeId             String
  conceptId              String
  conceptCode            String // snapshot del código al calcular
  conceptType            ConceptType // snapshot EARNING | DEDUCTION
  amount                 Decimal                 @db.Decimal(18, 2)
  // Campos de auditoría del motor de cálculo
  basis                  Decimal?                @db.Decimal(18, 2) // base de cálculo (salario diario, etc.)
  hours                  Decimal?                @db.Decimal(8, 2) // solo HE_DIURNA / HE_NOCTURNA
  rate                   Decimal?                @db.Decimal(6, 4) // porcentaje aplicado (ej: 0.0400)
  // Snapshot de salario — ADR-013 Decisión 2: FK + snapshot
  salaryHistoryId        String? // FK al SalaryHistory usado (trazabilidad)
  salarySnapshotAmount   Decimal?                @db.Decimal(18, 2) // monto vigente al calcular (inmutable)
  salarySnapshotCurrency PayrollPaymentCurrency?
  createdAt              DateTime                @default(now())

  payrollRun PayrollRun     @relation(fields: [payrollRunId], references: [id], onDelete: Restrict)
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  concept    PayrollConcept @relation(fields: [conceptId], references: [id], onDelete: Restrict)

  @@index([payrollRunId])
  @@index([companyId, employeeId])
  @@index([companyId, payrollRunId, employeeId])
}

// ─── Fase NOM-D: Prestaciones Sociales, Vacaciones, Utilidades, Liquidación ────
// ADR-014: arquitectura de beneficios laborales LOTTT Venezuela

enum BcvRateType {
  ACTIVA // Tasa activa BCV (Art. 143 LOTTT — valor por defecto)
  PROMEDIO // Tasa promedio BCV (alternativa)
}

// Tasa activa BCV mensual — fuente oficial para intereses sobre prestaciones (Art. 143 LOTTT)
// ADMIN-only: la tasa nunca viene del cliente en acciones de transacción (ADR-014 Dec. 2 / ADR-006 D-3)
model BcvBenefitRate {
  id              String      @id @default(cuid())
  companyId       String
  year            Int
  month           Int // 1–12
  annualRate      Decimal     @db.Decimal(5, 2) // porcentaje anual, ej: 17.50 = 17.5%
  rateType        BcvRateType @default(ACTIVA) // ACTIVA por mandato Art. 143 LOTTT
  source          String      @default("BCV") // "BCV" | "MANUAL"
  createdByUserId String
  createdAt       DateTime    @default(now())

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  accrualLines BenefitAccrualLine[]

  @@unique([companyId, year, month])
  @@index([companyId, year, month])
}

// Saldo corriente de prestaciones por empleado — proyección desnormalizada para performance.
// La fuente de verdad son los BenefitAccrualLine.
// Uno por empleado — creado al contratar, cerrado (isLiquidated) al finalizar la liquidación.
model BenefitBalance {
  id              String    @id @default(cuid())
  companyId       String
  employeeId      String    @unique // uno por empleado
  currentBalance  Decimal   @default(0) @db.Decimal(19, 4) // acumulado prestaciones
  interestBalance Decimal   @default(0) @db.Decimal(19, 4) // intereses BCV acumulados
  isLiquidated    Boolean   @default(false)
  liquidatedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee     Employee             @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  accrualLines BenefitAccrualLine[]
  advances     BenefitAdvance[]
  termination  Termination?

  @@index([companyId])
  @@index([companyId, isLiquidated])
}

enum BenefitAccrualType {
  QUARTERLY_ACCRUAL // accrual trimestral Art. 142 LOTTT — asiento obligatorio
  BCV_INTEREST // intereses Art. 143 LOTTT — asiento obligatorio
  ADJUSTMENT // corrección administrativa — asiento opcional
}

// Evento de acumulación de prestaciones — inmutable post-creación (ADR-014 Dec. 3)
// @@unique([benefitBalanceId, year, quarter, type]) para QUARTERLY_ACCRUAL previene doble-accrual (ADR-014 Dec. 1)
model BenefitAccrualLine {
  id                       String             @id @default(cuid())
  companyId                String
  benefitBalanceId         String
  type                     BenefitAccrualType
  // Período del evento
  year                     Int
  quarter                  Int? // 1–4 para QUARTERLY_ACCRUAL
  month                    Int? // 1–12 para BCV_INTEREST
  // Snapshot de salario integral al momento del accrual (inmutable post-creación — ADR-014 Dec. 3)
  dailyNormalWage          Decimal?           @db.Decimal(19, 4) // snapshot salario diario normal
  profitDaysAliquot        Decimal?           @db.Decimal(19, 4) // alícuota utilidades
  vacationBonusDaysAliquot Decimal?           @db.Decimal(19, 4) // alícuota bono vacacional
  integralDailyWage        Decimal?           @db.Decimal(19, 4) // = suma de los tres campos
  accrualDays              Int? // días base del período (siempre 5 — Art. 142)
  additionalDays           Decimal?           @db.Decimal(5, 2) // días adicionales por antigüedad (+2/año, máx 30 — Art. 142)
  // Montos del evento
  accrualAmount            Decimal            @db.Decimal(19, 4)
  runningBalance           Decimal            @db.Decimal(19, 4) // saldo acumulado post-evento
  // Tasa BCV aplicada (solo BCV_INTEREST)
  bcvRateId                String?
  appliedRate              Decimal?           @db.Decimal(5, 2) // snapshot de la tasa aplicada
  // Asiento contable — NON-NULL para QUARTERLY_ACCRUAL y BCV_INTEREST
  transactionId            String?            @unique
  notes                    String?
  createdByUserId          String
  createdAt                DateTime           @default(now())

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  benefitBalance BenefitBalance  @relation(fields: [benefitBalanceId], references: [id], onDelete: Restrict)
  bcvRate        BcvBenefitRate? @relation(fields: [bcvRateId], references: [id], onDelete: Restrict)
  transaction    Transaction?    @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  // Guard doble-accrual trimestral — P2002 si se intenta duplicar (ADR-014 Dec. 1)
  @@unique([benefitBalanceId, year, quarter, type])
  @@index([companyId])
  @@index([benefitBalanceId, createdAt(sort: Desc)])
  @@index([companyId, year, quarter])
}

// ─── Anticipo de Prestaciones Sociales (Art. 144 LOTTT) ──────────────────────
// Máximo 75% del saldo acumulado. Motivos tasados por la ley.
// Inmutable post-registro — cancelaciones vía asiento inverso + AuditLog.

enum BenefitAdvanceReason {
  HOUSING // Adquisición, construcción o remodelación de vivienda principal
  HEALTH // Gastos médicos graves del trabajador o su familia
  EDUCATION // Pago de estudios del trabajador o sus hijos
}

// F-04: Estado del anticipo en el flujo solicitud/aprobación (Art. 144 LOTTT)
enum BenefitAdvanceStatus {
  PENDING // Solicitud creada, pendiente de aprobación del patrono
  APPROVED // Aprobado: asiento GL generado y saldo descontado
  REJECTED // Rechazado: sin impacto en saldo
}

model BenefitAdvance {
  id               String               @id @default(cuid())
  companyId        String
  employeeId       String
  benefitBalanceId String
  amount           Decimal              @db.Decimal(19, 4) // monto del anticipo
  reason           BenefitAdvanceReason
  status           BenefitAdvanceStatus @default(APPROVED) // APPROVED para compatibilidad con registros directos
  notes            String?
  rejectionReason  String? // solo si status = REJECTED
  transactionId    String?              @unique // asiento débito al saldo (solo si APPROVED)
  createdByUserId  String
  approvedByUserId String? // quién aprobó (si flujo dos pasos)
  approvedAt       DateTime? // cuándo se aprobó
  rejectedAt       DateTime? // cuándo se rechazó
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  benefitBalance BenefitBalance @relation(fields: [benefitBalanceId], references: [id], onDelete: Restrict)
  transaction    Transaction?   @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@index([companyId, employeeId])
  @@index([companyId, status])
}

// Préstamos otorgados por la empresa al empleado, con descuento automático en nómina.
// La cuota se inyecta en cada PayrollRun como concepto PRESTAMO_EMP (DEDUCTION).
// Append-only en cuanto al saldo: remainingBalance decrece en approve(); nunca se edita directamente.
model EmployeeLoan {
  id                String     @id @default(cuid())
  companyId         String
  employeeId        String
  totalAmount       Decimal    @db.Decimal(20, 2)
  currency          String // "VES" | "USD"
  installments      Int // número total de cuotas
  installmentAmount Decimal    @db.Decimal(20, 2) // cuota fija = ceil(totalAmount / installments, 2)
  paidInstallments  Int        @default(0)
  remainingBalance  Decimal    @db.Decimal(20, 2)
  status            LoanStatus @default(ACTIVE)
  description       String?
  approvedAt        DateTime   @default(now())
  createdByUserId   String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([companyId, status])
  @@index([companyId, employeeId, status])
}

// Registro de vacaciones causadas por el empleado (disfrute o pago).
// Append-only — no se eliminan (ADR-003).
// isFractional = true → fracción calculada en liquidación final.
model VacationRecord {
  id              String   @id @default(cuid())
  companyId       String
  employeeId      String
  periodYear      Int // año de devengo
  vacationDays    Decimal  @db.Decimal(5, 2) // días hábiles causados (máx 90 — Zod)
  bonusDays       Decimal  @db.Decimal(5, 2) // bono vacacional causado (máx 90 — Zod)
  // Montos snapshot — dailyNormalWage calculado server-side, nunca del cliente (ADR-014 Dec. 3)
  dailyNormalWage Decimal  @db.Decimal(19, 4)
  vacationAmount  Decimal  @db.Decimal(19, 4)
  bonusAmount     Decimal  @db.Decimal(19, 4)
  // Período de disfrute
  startDate       DateTime @db.Date
  endDate         DateTime @db.Date
  isFractional    Boolean  @default(false) // true si es fracción en liquidación
  // Asiento contable
  transactionId   String?  @unique
  createdByUserId String
  createdAt       DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@unique([companyId, employeeId, periodYear, isFractional])
  @@index([companyId, employeeId])
  @@index([companyId, periodYear])
}

// Utilidades causadas por empleado por año fiscal (Art. 131-132 LOTTT).
// Append-only — no se eliminan (ADR-003).
// isFractional = true → fracción calculada en liquidación final.
model ProfitSharingRecord {
  id                 String   @id @default(cuid())
  companyId          String
  employeeId         String
  fiscalYear         Int // año fiscal de devengo
  profitDays         Decimal  @db.Decimal(5, 2) // días configurados (15–120 — Zod)
  fractionalDays     Decimal  @db.Decimal(5, 2) // días proporcionales al tiempo trabajado
  monthsWorked       Int // meses completos en el año fiscal
  // Snapshot de salario base — calculado server-side (ADR-014 Dec. 3)
  baseSalarySnapshot Decimal  @db.Decimal(19, 4) // promedio salarial del período
  profitAmount       Decimal  @db.Decimal(19, 4) // fractionalDays × (baseSalary/30)
  isFractional       Boolean  @default(false) // true si es fracción en liquidación
  // Asiento contable
  transactionId      String?  @unique
  createdByUserId    String
  createdAt          DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@unique([companyId, employeeId, fiscalYear])
  @@index([companyId, employeeId])
  @@index([companyId, fiscalYear])
}

enum TerminationStatus {
  DRAFT // editable — cálculos revisables
  FINALIZING // mutex en tránsito — indica failure parcial si persiste (ADR-014 Dec. 6)
  FINALIZED // terminal e inmutable — documento laboral generado
}

enum TerminationReason {
  RESIGNATION // Renuncia voluntaria
  DISMISSAL_JUSTIFIED // Despido justificado (Art. 79 LOTTT)
  DISMISSAL_UNJUSTIFIED // Despido injustificado — activa indemnización Art. 92
  MUTUAL_AGREEMENT // Mutuo acuerdo
  CONTRACT_EXPIRY // Vencimiento de contrato determinado
  DEATH // Fallecimiento
  DISABILITY // Incapacidad total permanente
}

// Liquidación Final — documento laboral inmutable post-FINALIZED (ADR-014 Dec. 4).
// Desnormalizado: cada monto es un snapshot calculado al momento de la liquidación.
// Double-finalization guard: updateMany mutex con estado FINALIZING (ADR-014 Dec. 6).
model Termination {
  id                            String            @id @default(cuid())
  companyId                     String
  employeeId                    String
  reason                        TerminationReason
  status                        TerminationStatus @default(DRAFT)
  terminationDate               DateTime          @db.Date
  // Trazabilidad de origen (ADR-014 Dec. 4)
  benefitBalanceId              String?           @unique
  // ── Componentes snapshot de la liquidación ──
  // Prestaciones
  benefitsAccumulatedAmount     Decimal           @default(0) @db.Decimal(19, 4)
  benefitsInterestAmount        Decimal           @default(0) @db.Decimal(19, 4)
  // Vacaciones fraccionadas
  vacationFractionalDays        Decimal           @default(0) @db.Decimal(5, 2)
  vacationFractionalAmount      Decimal           @default(0) @db.Decimal(19, 4)
  vacationBonusFractionalAmount Decimal           @default(0) @db.Decimal(19, 4)
  // Utilidades fraccionadas
  profitSharingFractionalDays   Decimal           @default(0) @db.Decimal(5, 2)
  profitSharingFractionalAmount Decimal           @default(0) @db.Decimal(19, 4)
  profitSharingBaseSalary       Decimal?          @db.Decimal(19, 4) // promedio snapshot (ADR-014 Dec. 8)
  // Indemnización Art. 92 (solo DISMISSAL_UNJUSTIFIED)
  indemnificationAmount         Decimal           @default(0) @db.Decimal(19, 4)
  // Preaviso Art. 86 LOTTT (solo DISMISSAL_UNJUSTIFIED — tramos por antigüedad)
  noticePeriodDays              Decimal           @default(0) @db.Decimal(5, 2)
  noticePeriodAmount            Decimal           @default(0) @db.Decimal(19, 4)
  // Otros conceptos pendientes
  pendingConceptsAmount         Decimal           @default(0) @db.Decimal(19, 4)
  pendingConceptsNotes          String?
  // Totales
  totalGrossAmount              Decimal           @default(0) @db.Decimal(19, 4)
  deductionsAmount              Decimal           @default(0) @db.Decimal(19, 4)
  totalNetAmount                Decimal           @default(0) @db.Decimal(19, 4)
  // Asiento contable de liquidación (NON-NULL al finalizar)
  transactionId                 String?           @unique
  // Idempotencia — previene doble-submit desde UI
  idempotencyKey                String            @unique
  // Auditoría
  createdByUserId               String
  finalizedByUserId             String?
  finalizedAt                   DateTime?
  deletedAt                     DateTime? // soft delete
  createdAt                     DateTime          @default(now())
  updatedAt                     DateTime          @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  benefitBalance BenefitBalance? @relation(fields: [benefitBalanceId], references: [id], onDelete: Restrict)
  transaction    Transaction?    @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@index([companyId, employeeId])
  @@index([companyId, status])
  @@index([companyId, terminationDate(sort: Desc)])
}

// Fase 35A: Vendor / Customer  |  ADR-028: code + groups
model VendorGroup {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  vendors Vendor[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Vendor {
  id                   String          @id @default(cuid())
  companyId            String
  name                 String
  rif                  String?
  email                String?
  phone                String?
  address              String?
  isSpecialContributor Boolean         @default(false) // Contribuyente Especial — determina si aplican retenciones IVA/ISLR
  // ADR-028: código de referencia + grupo
  code                 String?
  groupId              String?
  // Q3-2: CRM básico
  notes                String?         @db.Text
  category             ContactCategory @default(REGULAR)
  deletedAt            DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  company  Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  group    VendorGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  invoices Invoice[]
  // Fase 37B: Módulo Gastos
  expenses Expense[]

  @@unique([companyId, rif])
  @@unique([companyId, code])
  @@index([companyId, deletedAt])
}

model CustomerGroup {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customers Customer[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Customer {
  id        String          @id @default(cuid())
  companyId String
  name      String
  rif       String?
  email     String?
  phone     String?
  address   String?
  // ADR-028: código de referencia + grupo
  code      String?
  groupId   String?
  // Q3-2: CRM básico
  notes     String?         @db.Text
  category  ContactCategory @default(REGULAR)
  deletedAt DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  group    CustomerGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  invoices Invoice[]

  @@unique([companyId, rif])
  @@unique([companyId, code])
  @@index([companyId, deletedAt])
}

// Q3-2: Historial de interacciones por cliente/proveedor
model ContactNote {
  id         String   @id @default(cuid())
  companyId  String
  entityType String // 'CUSTOMER' | 'VENDOR'
  entityId   String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  createdBy  String // Clerk userId

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, entityType, entityId])
  @@index([companyId])
}

// ─── Q3-3: Presupuestos y Proyecciones ────────────────────────────────────────

enum BudgetStatus {
  DRAFT
  ACTIVE
  CLOSED
}

/// Presupuesto anual por empresa. Un presupuesto por año (unicidad companyId+periodYear+name).
model Budget {
  id         String       @id @default(cuid())
  companyId  String
  periodYear Int
  name       String       @default("Presupuesto Anual")
  status     BudgetStatus @default(DRAFT)
  createdBy  String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  company Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  lines   BudgetLine[]

  @@unique([companyId, periodYear, name])
  @@index([companyId])
}

/// Línea de presupuesto: importe anual por cuenta contable.
model BudgetLine {
  id        String  @id @default(cuid())
  budgetId  String
  companyId String
  accountId String
  amount    Decimal @db.Decimal(19, 4)
  notes     String? @db.Text

  budget  Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([budgetId, accountId])
  @@index([companyId])
}

// ─── PA-121 Outbox (ADR-019 D-1) ─────────────────────────────────────────────

enum SubmissionStatus {
  PENDING
  SENT
  FAILED
}

// Q3-2: CRM básico — categoría de contacto
enum ContactCategory {
  LEAD
  REGULAR
  VIP
}

model SeniatSubmission {
  id           String           @id @default(cuid())
  companyId    String
  invoiceId    String           @unique
  status       SubmissionStatus @default(PENDING)
  attempts     Int              @default(0)
  payload      Json
  lastResponse Json?
  sentAt       DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([companyId, status])
  @@index([status, createdAt])
}

// ─── Fase 35I: Firma Digital Híbrida (ADR-020) ───────────────────────────────

model CompanyCertificate {
  id           String   @id @default(cuid())
  companyId    String   @unique
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  commonName   String
  serialNumber String
  encryptedP12 Bytes // AES-256-GCM — NUNCA exponer al cliente
  thumbprint   String // SHA-256 del cert — identificador público
  issuedBy     String
  expiresAt    DateTime
  isSelfSigned Boolean  @default(true)
  createdAt    DateTime @default(now())
  createdBy    String // userId de Clerk
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

// ─── Fase 37A: InvoiceLine + CompanySettings — ADR-024 D-1 / D-2 ─────────────

model InvoiceLine {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  // Producto o servicio — nullable para servicios sin ítem registrado
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  // Snapshot inmutable al momento de facturar
  skuSnapshot  String? // null para servicios sin ítem registrado
  nameSnapshot String // obligatorio siempre

  // Descripción libre — anula nameSnapshot visualmente si está presente
  description String?

  // Cantidades y precios
  quantity Decimal            @db.Decimal(19, 4)
  unitId   String? // FK a InventoryItemUnit (unidad de venta)
  unit     InventoryItemUnit? @relation(fields: [unitId], references: [id], onDelete: Restrict)

  // Precios snapshot — inmutables al momento de emisión
  unitPriceUsd Decimal? @db.Decimal(19, 4)
  unitPriceVes Decimal  @db.Decimal(19, 4)

  // Alícuota de esta línea
  ivaRate IvaLineRate @default(GENERAL_16)

  // Totales calculados por el servicio — nunca por el cliente
  subtotal  Decimal @db.Decimal(19, 4) // quantity × unitPriceVes
  ivaAmount Decimal @db.Decimal(19, 4) // subtotal × tasaDecimal(ivaRate)
  total     Decimal @db.Decimal(19, 4) // subtotal + ivaAmount

  // Para líneas ADICIONAL_31: vincula IVA_ADICIONAL con IVA_GENERAL — misma semántica que InvoiceTaxLine
  luxuryGroupId String?

  // Movimiento de inventario generado en el mismo $transaction
  inventoryMovementId String?            @unique
  inventoryMovement   InventoryMovement? @relation(fields: [inventoryMovementId], references: [id], onDelete: Restrict)

  lineNumber Int // orden de aparición en la factura (1-based)

  // Soft delete — necesario para correcciones pre-confirmación sin romper inventoryMovementId
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([companyId, inventoryItemId])
  @@index([inventoryMovementId])
  @@index([invoiceId, deletedAt])
}

model CompanySettings {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  stockControlLevel StockControlLevel @default(WARN)

  // ADR-026: Cuentas contables para causación automática de facturas
  arAccountId                     String? // ASSET — Cuentas por Cobrar (facturas venta)
  apAccountId                     String? // LIABILITY — Proveedores (facturas compra)
  salesAccountId                  String? // REVENUE — ingreso por defecto (facturas venta)
  purchaseExpenseAccountId        String? // EXPENSE — gasto por defecto (facturas compra) [inventario periódico / sin uso en perpetuo]
  inventoryAccountId              String? // ASSET — Inventario de Mercancías (inventario perpetuo — Dr al registrar compra)
  ivaDFAccountId                  String? // LIABILITY — IVA Débito Fiscal (facturas venta)
  ivaCFAccountId                  String? // ASSET — IVA Crédito Fiscal (facturas compra)
  ivaRetentionPayableAccountId    String? // LIABILITY — Retenciones IVA por Pagar (GAP-03: split retención en GL compra)
  ivaRetentionReceivableAccountId String? // ASSET — IVA Retenido por Cobrar (Riesgo-6 audit: Dr al cobrar factura a CE que retiene)
  // ADR-027: Diferencial cambiario NIC 21 / VEN-NIF BA-5
  fxGainAccountId                 String? // REVENUE — Ganancia por diferencial cambiario
  fxLossAccountId                 String? // EXPENSE — Pérdida por diferencial cambiario

  arAccount                     Account? @relation("SettingsARAccount", fields: [arAccountId], references: [id], onDelete: Restrict)
  apAccount                     Account? @relation("SettingsAPAccount", fields: [apAccountId], references: [id], onDelete: Restrict)
  salesAccount                  Account? @relation("SettingsSalesAccount", fields: [salesAccountId], references: [id], onDelete: Restrict)
  purchaseExpenseAccount        Account? @relation("SettingsPurchaseExpenseAccount", fields: [purchaseExpenseAccountId], references: [id], onDelete: Restrict)
  inventoryAccount              Account? @relation("SettingsInventoryAccount", fields: [inventoryAccountId], references: [id], onDelete: Restrict)
  ivaDFAccount                  Account? @relation("SettingsIVADFAccount", fields: [ivaDFAccountId], references: [id], onDelete: Restrict)
  ivaCFAccount                  Account? @relation("SettingsIVACFAccount", fields: [ivaCFAccountId], references: [id], onDelete: Restrict)
  ivaRetentionPayableAccount    Account? @relation("SettingsIVARetentionPayableAccount", fields: [ivaRetentionPayableAccountId], references: [id], onDelete: Restrict)
  ivaRetentionReceivableAccount Account? @relation("SettingsIVARetentionReceivableAccount", fields: [ivaRetentionReceivableAccountId], references: [id], onDelete: Restrict)
  fxGainAccount                 Account? @relation("SettingsFxGainAccount", fields: [fxGainAccountId], references: [id], onDelete: Restrict)
  fxLossAccount                 Account? @relation("SettingsFxLossAccount", fields: [fxLossAccountId], references: [id], onDelete: Restrict)
  // ADR-030: cuenta IGTF por Pagar — distinta de IVA DF (cuenta 2115 o similar en PUC venezolano)
  igtfPayableAccountId          String?
  igtfPayableAccount            Account? @relation("SettingsIGTFPayableAccount", fields: [igtfPayableAccountId], references: [id], onDelete: Restrict)

  // Bloque B Item 2: Firma del Contador Público Colegiado (CPC) para reportes
  accountantName      String? // Nombre completo del CPC
  accountantTitle     String? // Cargo / título (ej. "Contador Público Colegiado")
  accountantCpcNumber String? // Número de inscripción en el Colegio de CP

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Fase 37B: Módulo Gastos — ADR-024 D-3 ───────────────────────────────────

enum ExpenseStatus {
  DRAFT // registrado pero no confirmado — editable
  CONFIRMED // confirmado — genera asiento contable si accountId configurado
  VOIDED // anulado — nunca DELETE
}

model ExpenseCategory {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name        String
  description String?
  // Cuenta contable por defecto para esta categoría (override posible a nivel Expense)
  accountId   String?
  account     Account?  @relation("ExpenseCategoryAccount", fields: [accountId], references: [id], onDelete: Restrict)
  isDefault   Boolean   @default(false) // categorías semilla — el usuario puede agregar más
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  expenses Expense[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, deletedAt])
}

model Expense {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  // Proveedor — vendorId O supplierName obligatorio (validación Zod)
  vendorId     String?
  vendor       Vendor? @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  supplierName String? // texto libre si el proveedor no está registrado

  // Detalle del gasto
  concept    String
  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Montos — siempre Decimal (ADR-002 / R-5)
  amount       Decimal  @db.Decimal(19, 4)
  currency     Currency @default(VES)
  // exchangeRate obligatorio si currency != VES, null si VES
  exchangeRate Decimal? @db.Decimal(19, 6)
  // amountVes = amount × exchangeRate (o amount si VES)
  amountVes    Decimal  @db.Decimal(19, 4)

  // IVA
  hasIva    Boolean  @default(false)
  ivaAmount Decimal? @db.Decimal(19, 4)

  // Deducibilidad ISLR (Decreto 1808)
  isDeductible Boolean @default(true)

  // Factura del proveedor (opcional)
  invoiceNumber String?
  invoiceDate   DateTime? @db.Date

  // Comprobante digital — URL a Object Storage (R-2: nunca en BD)
  attachmentUrl String?

  // Contabilidad — nullable hasta que el ACCOUNTANT lo configura
  transactionId    String?      @unique
  transaction      Transaction? @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  // Cuenta de gastos — puede diferir de la cuenta de la categoría
  expenseAccountId String?
  expenseAccount   Account?     @relation("ExpenseAccount", fields: [expenseAccountId], references: [id], onDelete: Restrict)

  status         ExpenseStatus @default(DRAFT)
  idempotencyKey String        @unique

  // Soft delete
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  createdBy String
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, categoryId])
  @@index([companyId, status])
  @@index([companyId, invoiceDate])
  @@index([companyId, deletedAt])
}

// ─── Sprint 3: Suscripciones y Facturación ────────────────────────────────────

enum SubscriptionPlan {
  TRIAL
  MONTHLY
  ANNUAL
  EARLY_ADOPTER
}

enum SubscriptionStatus {
  TRIALING // En período de prueba (14 días)
  ACTIVE // Suscripción activa y al día
  PAST_DUE // Pago vencido — acceso suspendido
  CANCELLED // Cancelada por el usuario
  EXPIRED // Venció sin renovación
}

enum BillingPaymentStatus {
  PENDING // Esperando pago
  CONFIRMING // En confirmación en blockchain
  CONFIRMED // Pagado y confirmado
  FAILED // Falló el pago
  EXPIRED // Caducó sin pago
  REFUNDED // Reembolsado
}

model Subscription {
  id                  String             @id @default(cuid())
  companyId           String             @unique
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  plan                SubscriptionPlan
  status              SubscriptionStatus
  trialEndsAt         DateTime? // Solo para status TRIALING
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean            @default(false)
  priceUsdCents       Int // Precio en centavos USD (ej. 4900 = $49.00)
  earlyAdopterSlot    Int? // 1–10, solo para EARLY_ADOPTER
  referredByCompanyId String?
  referredBy          Company?           @relation("SubscriptionReferral", fields: [referredByCompanyId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  payments SubscriptionPayment[]

  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id                   String               @id @default(cuid())
  subscriptionId       String
  subscription         Subscription         @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  nowpaymentsOrderId   String?              @unique
  nowpaymentsPaymentId String?              @unique
  amountUsdCents       Int
  currency             String // "USDT", "BTC", etc.
  status               BillingPaymentStatus @default(PENDING)
  paidAt               DateTime?
  metadata             Json? // Raw webhook payload NOWPayments
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([subscriptionId])
  @@map("subscription_payments")
}

// ─── Fase 36D: IncomeDistribution — Distribución de Ingresos (ADR-023) ────────

enum IncomeDistributionStatus {
  DRAFT
  APPLIED
  VOID
}

model IncomeDistribution {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation("IncomeDistributions", fields: [companyId], references: [id], onDelete: Restrict)

  referenceNumber String?                  @unique @db.VarChar(50)
  description     String?                  @db.Text
  date            DateTime                 @db.Date
  status          IncomeDistributionStatus @default(DRAFT)

  currencyCode        String  @default("VES") @db.VarChar(3)
  totalAmountOriginal Decimal @db.Decimal(18, 2)
  totalAmountVes      Decimal @db.Decimal(18, 2)
  exchangeRate        Decimal @default(1) @db.Decimal(8, 6)

  originAccountId String
  originAccount   Account @relation("IncomeDistributionOrigin", fields: [originAccountId], references: [id], onDelete: Restrict)

  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  idempotencyKey String? @unique @db.VarChar(255)

  voidReason String?   @db.Text
  voidedAt   DateTime?
  voidedBy   String?   @db.VarChar(255)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String    @db.VarChar(255)

  lines  IncomeDistributionLine[]
  audits IncomeDistributionAudit[]

  @@index([companyId, status])
  @@index([companyId, date])
  @@map("income_distributions")
}

model IncomeDistributionLine {
  id             String             @id @default(cuid())
  distributionId String
  distribution   IncomeDistribution @relation(fields: [distributionId], references: [id], onDelete: Restrict)

  recipientCompanyId String
  recipientCompany   Company @relation("IncomeDistributionRecipients", fields: [recipientCompanyId], references: [id], onDelete: Restrict)

  accountId String
  account   Account @relation("IncomeDistributionLineAccounts", fields: [accountId], references: [id], onDelete: Restrict)

  percentageShare Decimal @db.Decimal(5, 2)
  amountVes       Decimal @db.Decimal(18, 2)
  lineDescription String? @db.Text
  lineNumber      Int

  createdAt DateTime @default(now())

  @@unique([distributionId, recipientCompanyId])
  @@index([distributionId])
  @@map("income_distribution_lines")
}

model IncomeDistributionAudit {
  id             String             @id @default(cuid())
  distributionId String
  distribution   IncomeDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)

  action         String @db.VarChar(50)
  changesSummary Json?

  userId    String  @db.VarChar(255)
  ipAddress String? @db.VarChar(45)
  userAgent String? @db.Text

  createdAt DateTime @default(now())

  @@index([distributionId])
  @@map("income_distribution_audits")
}

// ─── Fase 35D: Caja Chica (Fondo Fijo) ────────────────────────────────────────

enum CajaCajaStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum CajaCajaDepositStatus {
  PENDING
  POSTED
  VOIDED
}

enum CajaCajaMovementStatus {
  PENDING
  APPROVED
  REIMBURSED
  VOIDED
}

enum CajaCajaReimbursementStatus {
  DRAFT
  POSTED
  VOIDED
}

// ─── Fase 39: Facturación Digital PA-102 (ADR-031) ───────────────────────────

enum DigitalInvoiceProviderType {
  NONE // Esquema antiguo — correlativo interno
  HKA // The Factory HKA
}

enum ControlNumberSource {
  INTERNAL // Generado por ContaFlow (esquema pre-PA-102)
  HKA // Generado por The Factory HKA
  CONTINGENCY // Emitido en contingencia (proveedor no disponible)
}

model CajaCaja {
  id         String         @id @default(cuid())
  companyId  String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name       String         @db.VarChar(255)
  accountId  String
  account    Account        @relation("CajaCajaAccount", fields: [accountId], references: [id], onDelete: Restrict)
  currency   Currency       @default(VES)
  maxBalance Decimal        @db.Decimal(19, 4)
  status     CajaCajaStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  createdBy  String         @db.VarChar(255)
  closedAt   DateTime?
  closedBy   String?        @db.VarChar(255)

  deposits       CajaCajaDeposit[]
  movements      CajaCajaMovement[]
  reimbursements CajaCajaReimbursement[]

  @@unique([companyId, accountId])
  @@index([companyId, status])
  @@map("caja_cajas")
}

model CajaCajaDeposit {
  id                   String                @id @default(cuid())
  companyId            String
  cajaCajaId           String
  cajaCaja             CajaCaja              @relation(fields: [cajaCajaId], references: [id], onDelete: Restrict)
  date                 DateTime              @db.Date
  amount               Decimal               @db.Decimal(19, 4)
  description          String                @db.VarChar(500)
  supportingDocumentId String?               @db.VarChar(255)
  transactionId        String?               @unique
  transaction          Transaction?          @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  status               CajaCajaDepositStatus @default(PENDING)
  voidedAt             DateTime?
  voidReason           String?               @db.Text
  createdAt            DateTime              @default(now())
  createdBy            String                @db.VarChar(255)

  @@index([companyId, cajaCajaId])
  @@map("caja_caja_deposits")
}

model CajaCajaMovement {
  id                   String                 @id @default(cuid())
  companyId            String
  cajaCajaId           String
  cajaCaja             CajaCaja               @relation(fields: [cajaCajaId], references: [id], onDelete: Restrict)
  date                 DateTime               @db.Date
  voucherNumber        String                 @db.VarChar(50)
  concept              String                 @db.VarChar(255)
  description          String?                @db.Text
  expenseAccountId     String
  expenseAccount       Account                @relation("CajaCajaExpenseAccount", fields: [expenseAccountId], references: [id], onDelete: Restrict)
  amount               Decimal                @db.Decimal(19, 4)
  currency             Currency               @default(VES)
  supportingDocumentId String?                @db.VarChar(255)
  notes                String?                @db.Text
  status               CajaCajaMovementStatus @default(PENDING)
  approvedAt           DateTime?
  approvedBy           String?                @db.VarChar(255)
  reimbursementId      String?
  reimbursement        CajaCajaReimbursement? @relation(fields: [reimbursementId], references: [id], onDelete: Restrict)
  voidedAt             DateTime?
  voidReason           String?                @db.Text
  createdAt            DateTime               @default(now())
  createdBy            String                 @db.VarChar(255)

  @@unique([companyId, voucherNumber])
  @@index([companyId, cajaCajaId])
  @@index([status, date])
  @@map("caja_caja_movements")
}

model CajaCajaReimbursement {
  id                  String                      @id @default(cuid())
  companyId           String
  cajaCajaId          String
  cajaCaja            CajaCaja                    @relation(fields: [cajaCajaId], references: [id], onDelete: Restrict)
  monthYear           String                      @db.VarChar(7)
  reimbursementNumber String                      @db.VarChar(50)
  totalExpensesVes    Decimal                     @db.Decimal(19, 4)
  transactionId       String?                     @unique
  transaction         Transaction?                @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  status              CajaCajaReimbursementStatus @default(DRAFT)
  postedAt            DateTime?
  postedBy            String?                     @db.VarChar(255)
  voidedAt            DateTime?
  voidReason          String?                     @db.Text
  createdAt           DateTime                    @default(now())
  createdBy           String                      @db.VarChar(255)

  movements CajaCajaMovement[]

  @@unique([companyId, reimbursementNumber])
  @@unique([companyId, cajaCajaId, monthYear])
  @@index([companyId, cajaCajaId])
  @@map("caja_caja_reimbursements")
}

// ─── ADR-029: Adjuntos de Comprobante de Pago ─────────────────────────────────
// Contenido en Vercel Blob — solo metadatos + contentHash en BD (R-2)
// Flujo: handleUpload (API route) + upload() client-side (archivo nunca pasa por Next.js)
model PaymentAttachment {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  paymentRecordId String
  paymentRecord   PaymentRecord @relation(fields: [paymentRecordId], references: [id], onDelete: Restrict)
  // Metadatos del archivo
  fileName        String // nombre original del archivo (ej. "comprobante-zelle.pdf")
  mimeType        String // MIME validado: application/pdf | image/jpeg | image/png | image/webp
  sizeBytes       Int // tamaño en bytes (máx. 5 242 880 — 5 MB)
  // Vercel Blob
  blobUrl         String // URL pública de Vercel Blob (https://*.vercel-storage.com/...)
  blobKey         String // pathname del blob (companyId/payments/paymentId/uuid.ext)
  // Integridad (R-2)
  contentHash     String // SHA-256 hex del contenido del archivo (calculado client-side)
  // Auditoría
  uploadedBy      String // userId Clerk
  uploadedAt      DateTime      @default(now())
  // Soft delete — conservar en Blob para auditoría PA-121 (ADR-029 D-6)
  deletedAt       DateTime?
  deletedBy       String? // userId Clerk

  @@unique([companyId, blobKey])
  @@index([companyId])
  @@index([paymentRecordId])
}
