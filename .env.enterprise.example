# ContaFlow — Variables de entorno para despliegue self-hosted (Tier 3)
# Copiar este archivo como .env.production y completar todos los valores.
# NO commitear .env.production al repositorio.
#
# Documentación completa: ADR-017 — Enterprise Deployment Tiers

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS POSTGRESQL
# ─────────────────────────────────────────────────────────────────────────────
# Usuario de la base de datos
POSTGRES_USER=contaflow

# Contraseña — usar mínimo 32 caracteres aleatorios
# Generar: openssl rand -base64 32
POSTGRES_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA

# Nombre de la base de datos
POSTGRES_DB=contaflow

# ─────────────────────────────────────────────────────────────────────────────
# CLERK — AUTENTICACIÓN (CLOUD REQUERIDO)
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANTE: Clerk no es self-hosted. Crear cuenta en clerk.com.
# Plan gratuito soporta hasta 10,000 MAU.
# Para auth 100% on-premise contactar al equipo ContaFlow.
#
# Dashboard: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────
# REDIS — RATE LIMITING (OPCIONAL)
# ─────────────────────────────────────────────────────────────────────────────
# Si se usa docker-compose.yml incluido, configurar:
# UPSTASH_REDIS_REST_URL=http://redis:80
# UPSTASH_REDIS_REST_TOKEN=local
#
# Si se prefiere Upstash cloud: https://console.upstash.com
# Si no se configura → rate limiting es no-op (permite todas las solicitudes)
UPSTASH_REDIS_REST_URL=http://redis:80
UPSTASH_REDIS_REST_TOKEN=local

# ─────────────────────────────────────────────────────────────────────────────
# ALMACENAMIENTO DE OBJETOS — REPORTES FISCALES (R-2)
# ─────────────────────────────────────────────────────────────────────────────
# MinIO self-hosted (incluido en docker-compose.yml)
# Para S3 de AWS: cambiar STORAGE_ENDPOINT a https://s3.amazonaws.com
STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET=contaflow-fiscal

# Credenciales MinIO — usar mínimo 16 caracteres
MINIO_ROOT_USER=contaflow
MINIO_ROOT_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA_MINIO

# ─────────────────────────────────────────────────────────────────────────────
# INTELIGENCIA ARTIFICIAL
# ─────────────────────────────────────────────────────────────────────────────
# Al menos uno requerido para: OCR facturas, auto-conciliación bancaria,
# asistente contable, detector de anomalías, resumen de tareas pendientes.
#
# Gemini (Google AI Studio — gratuito con límites): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (alternativa rápida — gratuito con límites): https://console.groq.com/keys
GROQ_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# SENTRY — MONITOREO DE ERRORES (OPCIONAL)
# ─────────────────────────────────────────────────────────────────────────────
# Dejar vacío para deshabilitar. Crear proyecto en sentry.io.
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE LA APP
# ─────────────────────────────────────────────────────────────────────────────
# Puerto donde escucha la app (default: 3000)
APP_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# URL DE LA APLICACIÓN
# ─────────────────────────────────────────────────────────────────────────────
# URL pública sin trailing slash. Requerida para CSRF allowedOrigins y
# para generar los enlaces del Portal del Empleado.
NEXT_PUBLIC_APP_URL=https://contaflow.example.com

# ─────────────────────────────────────────────────────────────────────────────
# QSTASH (Upstash) — Webhooks y reintentos SENIAT
# ─────────────────────────────────────────────────────────────────────────────
# Upstash Console → QStash. Si no se configura, los envíos al SENIAT se
# persisten en DB pero no se encolan para reintento automático.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# PAGOS (NOWPayments) — OPCIONAL
# ─────────────────────────────────────────────────────────────────────────────
# Configurar cuando esté disponible el dominio de producción.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET_KEY=
NOWPAYMENTS_SANDBOX=false

# ─────────────────────────────────────────────────────────────────────────────
# PORTAL DEL EMPLEADO
# ─────────────────────────────────────────────────────────────────────────────
# Clave HMAC-SHA256 para firmar tokens JWT del portal de autoservicio.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OBLIGATORIO — sin este secreto los tokens son inválidos en producción.
EMPLOYEE_PORTAL_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# FIRMA DIGITAL (FASE 35I)
# ─────────────────────────────────────────────────────────────────────────────
# Clave AES-256 para cifrar certificados .p12 en la base de datos.
# Generar con: node -e "require('crypto').randomBytes(32).toString('hex')"
# OBLIGATORIO para usar firma digital de documentos fiscales.
CERT_ENCRYPTION_SECRET=
